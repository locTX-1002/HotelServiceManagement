<UserControl x:Class="FUHotelManagementWPF.Views.Invoices.InvoicesView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:enums="clr-namespace:BusinessObjects.Enums;assembly=BusinessObjects"
             xmlns:hc="https://handyorg.github.io/handycontrol">
    <Grid Background="{StaticResource SurfaceBrush}" Margin="24">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="14" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <Grid Grid.Row="0">
            <StackPanel>
                <TextBlock Text="Hoá đơn &amp; thanh toán" Style="{StaticResource PageTitleText}" />
                <TextBlock Text="Quản lý phụ thu, lập hoá đơn và ghi nhận thanh toán theo lượt ở."
                           Style="{StaticResource CaptionText}" Margin="0,4,0,0" />
            </StackPanel>
            <Button Content="Tải lại" Style="{StaticResource GhostButton}"
                    HorizontalAlignment="Right" VerticalAlignment="Center"
                    Command="{Binding RefreshCommand}" />
        </Grid>

        <Grid Grid.Row="2">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="275" />
                <ColumnDefinition Width="14" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>

            <Border Grid.Column="0" Style="{StaticResource Card}" Padding="0">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>
                    <StackPanel Margin="18,16,18,10">
                        <TextBlock Text="Lượt ở đang hoạt động" Style="{StaticResource SectionTitleText}" />
                        <TextBlock Text="Chọn phòng để quản lý hoá đơn."
                                   Style="{StaticResource CaptionText}" Margin="0,3,0,0" />
                    </StackPanel>
                    <ListBox Grid.Row="1" ItemsSource="{Binding ActiveStays}"
                             SelectedItem="{Binding SelectedStay}"
                             BorderThickness="0" Background="Transparent"
                             ScrollViewer.HorizontalScrollBarVisibility="Disabled">
                        <ListBox.ItemTemplate>
                            <DataTemplate>
                                <Border Padding="14,10" BorderBrush="{StaticResource LineBrush}"
                                        BorderThickness="0,1,0,0">
                                    <StackPanel>
                                        <TextBlock FontWeight="SemiBold">
                                            <Run Text="Phòng " />
                                            <Run Text="{Binding Reservation.Room.RoomNumber, Mode=OneWay}" />
                                        </TextBlock>
                                        <TextBlock Style="{StaticResource CaptionText}" Margin="0,3,0,0">
                                            <Run Text="{Binding Reservation.Guest.FullName, Mode=OneWay}" />
                                            <Run Text=" · " />
                                            <Run Text="{Binding ActualCheckIn, Mode=OneWay, StringFormat={}{0:dd/MM/yyyy HH:mm}}" />
                                        </TextBlock>
                                    </StackPanel>
                                </Border>
                            </DataTemplate>
                        </ListBox.ItemTemplate>
                    </ListBox>
                </Grid>
            </Border>

            <Grid Grid.Column="2">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="12" />
                    <RowDefinition Height="*" />
                </Grid.RowDefinitions>

                <Border Grid.Row="0" Padding="12,9" CornerRadius="8"
                        Background="{StaticResource DangerSoftBrush}">
                    <Border.Style>
                        <Style TargetType="Border">
                            <Setter Property="Visibility" Value="Visible" />
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding ErrorMessage}" Value="">
                                    <Setter Property="Visibility" Value="Collapsed" />
                                </DataTrigger>
                                <DataTrigger Binding="{Binding ErrorMessage}" Value="{x:Null}">
                                    <Setter Property="Visibility" Value="Collapsed" />
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </Border.Style>
                    <TextBlock Text="{Binding ErrorMessage}" Foreground="{StaticResource DangerBrush}"
                               TextWrapping="Wrap" />
                </Border>

                <TabControl Grid.Row="2">
                    <TabItem Header="Hoá đơn">
                        <ScrollViewer VerticalScrollBarVisibility="Auto">
                            <StackPanel Margin="4,14,4,4">
                                <Border Style="{StaticResource Card}">
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="16" />
                                            <ColumnDefinition Width="220" />
                                        </Grid.ColumnDefinitions>

                                        <StackPanel>
                                            <TextBlock Text="Tổng quan" Style="{StaticResource SectionTitleText}" />
                                            <TextBlock Text="{Binding InvoiceStatusText}"
                                                       Foreground="{StaticResource BrandBrush}"
                                                       FontWeight="SemiBold" Margin="0,5,0,14" />
                                            <Grid>
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="*" />
                                                    <ColumnDefinition Width="*" />
                                                </Grid.ColumnDefinitions>
                                                <StackPanel Grid.Column="0">
                                                    <TextBlock Text="Tiền phòng" Style="{StaticResource CaptionText}" />
                                                    <TextBlock Text="{Binding Invoice.RoomCharge, StringFormat={}{0:N0} đ}"
                                                               Style="{StaticResource BodyText}" Margin="0,3,0,10" />
                                                    <TextBlock Text="Tiền dịch vụ" Style="{StaticResource CaptionText}" />
                                                    <TextBlock Text="{Binding Invoice.ServiceCharge, StringFormat={}{0:N0} đ}"
                                                               Style="{StaticResource BodyText}" Margin="0,3,0,10" />
                                                    <TextBlock Text="Phụ thu" Style="{StaticResource CaptionText}" />
                                                    <TextBlock Text="{Binding Invoice.SurchargeAmount, StringFormat={}{0:N0} đ}"
                                                               Style="{StaticResource BodyText}" Margin="0,3,0,0" />
                                                </StackPanel>
                                                <StackPanel Grid.Column="1">
                                                    <TextBlock Text="Giảm giá" Style="{StaticResource CaptionText}" />
                                                    <TextBlock Text="{Binding Invoice.DiscountAmount, StringFormat={}{0:N0} đ}"
                                                               Style="{StaticResource BodyText}" Margin="0,3,0,10" />
                                                    <TextBlock Text="Đã thanh toán" Style="{StaticResource CaptionText}" />
                                                    <TextBlock Text="{Binding PaidAmount, StringFormat={}{0:N0} đ}"
                                                               Style="{StaticResource BodyText}" Margin="0,3,0,10" />
                                                    <TextBlock Text="Còn lại" Style="{StaticResource CaptionText}" />
                                                    <TextBlock Text="{Binding RemainingAmount, StringFormat={}{0:N0} đ}"
                                                               Foreground="{StaticResource DangerBrush}"
                                                               FontWeight="SemiBold" Margin="0,3,0,0" />
                                                </StackPanel>
                                            </Grid>
                                        </StackPanel>

                                        <StackPanel Grid.Column="2">
                                            <TextBlock Text="KHUYẾN MÃI" Style="{StaticResource FieldLabel}" />
                                            <ComboBox ItemsSource="{Binding Promotions}"
                                                      SelectedItem="{Binding SelectedPromotion}"
                                                      DisplayMemberPath="Code"
                                                      IsEditable="True"
                                                      Text="{Binding PromotionCode, UpdateSourceTrigger=PropertyChanged}" />
                                            <TextBlock Text="Tổng phải trả" Style="{StaticResource CaptionText}"
                                                       Margin="0,20,0,3" />
                                            <TextBlock Text="{Binding Invoice.TotalAmount, StringFormat={}{0:N0} đ}"
                                                       Style="{StaticResource PageTitleText}"
                                                       Foreground="{StaticResource BrandBrush}" />
                                            <Button Content="Lập / tính lại hoá đơn"
                                                    Style="{StaticResource PrimaryButton}"
                                                    Margin="0,18,0,0"
                                                    IsEnabled="{Binding CanPrepareInvoice}"
                                                    Command="{Binding PrepareInvoiceCommand}" />
                                            <Button Content="Huỷ hoá đơn"
                                                    Style="{StaticResource GhostButton}"
                                                    Margin="0,8,0,0"
                                                    IsEnabled="{Binding CanCancelInvoice}"
                                                    Command="{Binding CancelInvoiceCommand}" />
                                        </StackPanel>
                                    </Grid>
                                </Border>
                            </StackPanel>
                        </ScrollViewer>
                    </TabItem>

                    <TabItem Header="Phụ thu">
                        <Grid Margin="4,14,4,4">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="10" />
                                <RowDefinition Height="*" />
                            </Grid.RowDefinitions>
                            <Grid>
                                <TextBlock Text="Phụ thu của lượt ở" Style="{StaticResource SectionTitleText}" />
                                <Button Content="Thêm phụ thu" Style="{StaticResource PrimaryButton}"
                                        HorizontalAlignment="Right" IsEnabled="{Binding CanEditSurcharges}"
                                        Command="{Binding AddSurchargeCommand}" />
                            </Grid>
                            <DataGrid Grid.Row="2" ItemsSource="{Binding Surcharges}"
                                      AutoGenerateColumns="False" CanUserAddRows="False"
                                      HeadersVisibility="Column" GridLinesVisibility="None">
                                <DataGrid.Columns>
                                    <DataGridTextColumn Header="Phụ thu"
                                                        Binding="{Binding SurchargeItem.Name}" Width="*" />
                                    <DataGridTextColumn Header="Đơn vị"
                                                        Binding="{Binding SurchargeItem.Unit}" Width="90" />
                                    <DataGridTextColumn Header="Số lượng"
                                                        Binding="{Binding Quantity}" Width="80" />
                                    <DataGridTextColumn Header="Đơn giá"
                                                        Binding="{Binding UnitPriceSnapshot, StringFormat={}{0:N0} đ}"
                                                        Width="120" />
                                    <DataGridTextColumn Header="Thành tiền"
                                                        Binding="{Binding Subtotal, StringFormat={}{0:N0} đ}"
                                                        Width="130" />
                                    <DataGridTemplateColumn Header="" Width="150">
                                        <DataGridTemplateColumn.CellTemplate>
                                            <DataTemplate>
                                                <StackPanel Orientation="Horizontal">
                                                    <Button Content="Sửa" Style="{StaticResource GhostButton}"
                                                            Padding="10,5"
                                                            IsEnabled="{Binding DataContext.CanEditSurcharges,
                                                                                RelativeSource={RelativeSource AncestorType=DataGrid}}"
                                                            Command="{Binding DataContext.EditSurchargeCommand,
                                                                              RelativeSource={RelativeSource AncestorType=DataGrid}}"
                                                            CommandParameter="{Binding}" />
                                                    <Button Content="Xoá" Style="{StaticResource GhostButton}"
                                                            Padding="10,5" Margin="6,0,0,0"
                                                            IsEnabled="{Binding DataContext.CanEditSurcharges,
                                                                                RelativeSource={RelativeSource AncestorType=DataGrid}}"
                                                            Command="{Binding DataContext.DeleteSurchargeCommand,
                                                                              RelativeSource={RelativeSource AncestorType=DataGrid}}"
                                                            CommandParameter="{Binding}" />
                                                </StackPanel>
                                            </DataTemplate>
                                        </DataGridTemplateColumn.CellTemplate>
                                    </DataGridTemplateColumn>
                                </DataGrid.Columns>
                            </DataGrid>
                        </Grid>
                    </TabItem>

                    <TabItem Header="Thanh toán">
                        <Grid Margin="4,14,4,4">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="10" />
                                <RowDefinition Height="*" />
                            </Grid.RowDefinitions>
                            <Grid>
                                <StackPanel>
                                    <TextBlock Text="Lịch sử thanh toán" Style="{StaticResource SectionTitleText}" />
                                    <TextBlock Style="{StaticResource CaptionText}" Margin="0,3,0,0">
                                        <Run Text="Còn lại: " />
                                        <Run Text="{Binding RemainingAmount, Mode=OneWay, StringFormat={}{0:N0} đ}"
                                             FontWeight="SemiBold" />
                                    </TextBlock>
                                </StackPanel>
                                <Button Content="Ghi nhận thanh toán"
                                        Style="{StaticResource PrimaryButton}"
                                        HorizontalAlignment="Right"
                                        IsEnabled="{Binding CanRecordPayment}"
                                        Command="{Binding RecordPaymentCommand}" />
                            </Grid>
                            <DataGrid Grid.Row="2" ItemsSource="{Binding Payments}"
                                      AutoGenerateColumns="False" CanUserAddRows="False"
                                      HeadersVisibility="Column" GridLinesVisibility="None">
                                <DataGrid.Columns>
                                    <DataGridTextColumn Header="Thời gian"
                                                        Binding="{Binding PaymentDate, StringFormat={}{0:dd/MM/yyyy HH:mm}}"
                                                        Width="150" />
                                    <DataGridTextColumn Header="Số tiền"
                                                        Binding="{Binding Amount, StringFormat={}{0:N0} đ}"
                                                        Width="130" />
                                    <DataGridTextColumn Header="Phương thức"
                                                        Binding="{Binding PaymentMethod}" Width="120" />
                                    <DataGridTextColumn Header="Mã giao dịch"
                                                        Binding="{Binding TransactionId}" Width="*" />
                                    <DataGridTextColumn Header="Trạng thái"
                                                        Binding="{Binding Status}" Width="100" />
                                    <DataGridTemplateColumn Header="" Width="90">
                                        <DataGridTemplateColumn.CellTemplate>
                                            <DataTemplate>
                                                <Button Content="Void" Padding="10,5"
                                                        Command="{Binding DataContext.VoidPaymentCommand,
                                                                          RelativeSource={RelativeSource AncestorType=DataGrid}}"
                                                        CommandParameter="{Binding}">
                                                    <Button.Style>
                                                        <Style TargetType="Button"
                                                               BasedOn="{StaticResource GhostButton}">
                                                            <Setter Property="IsEnabled" Value="False" />
                                                            <Style.Triggers>
                                                                <MultiDataTrigger>
                                                                    <MultiDataTrigger.Conditions>
                                                                        <Condition Binding="{Binding DataContext.CanVoidPayment,
                                                                                                     RelativeSource={RelativeSource AncestorType=DataGrid}}"
                                                                                   Value="True" />
                                                                        <Condition Binding="{Binding Status}"
                                                                                   Value="{x:Static enums:PaymentStatus.Completed}" />
                                                                    </MultiDataTrigger.Conditions>
                                                                    <Setter Property="IsEnabled" Value="True" />
                                                                </MultiDataTrigger>
                                                            </Style.Triggers>
                                                        </Style>
                                                    </Button.Style>
                                                </Button>
                                            </DataTemplate>
                                        </DataGridTemplateColumn.CellTemplate>
                                    </DataGridTemplateColumn>
                                </DataGrid.Columns>
                            </DataGrid>
                        </Grid>
                    </TabItem>
                </TabControl>

                <ProgressBar Grid.RowSpan="3" IsIndeterminate="True" Height="4"
                             VerticalAlignment="Top"
                             Visibility="{Binding IsLoading, Converter={StaticResource BoolToVis}}" />
            </Grid>
        </Grid>
    </Grid>
</UserControl>
