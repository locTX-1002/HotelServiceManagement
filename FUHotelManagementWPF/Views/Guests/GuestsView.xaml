<UserControl x:Class="FUHotelManagementWPF.Views.Guests.GuestsView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:hc="https://handyorg.github.io/handycontrol"
             xmlns:enums="clr-namespace:BusinessObjects.Enums;assembly=BusinessObjects">
    <UserControl.Resources>
        <!-- Badge phân loại khách -->
        <Style x:Key="GuestTagBadge" TargetType="Border" BasedOn="{StaticResource BadgeBase}">
            <Setter Property="Background" Value="{StaticResource SurfaceAltBrush}" />
            <Setter Property="TextElement.Foreground" Value="{StaticResource InkSoftBrush}" />
            <Style.Triggers>
                <DataTrigger Binding="{Binding Tag}" Value="{x:Static enums:GuestTag.Vip}">
                    <Setter Property="Background" Value="{StaticResource WarningSoftBrush}" />
                    <Setter Property="TextElement.Foreground" Value="{StaticResource WarningBrush}" />
                </DataTrigger>
                <DataTrigger Binding="{Binding Tag}" Value="{x:Static enums:GuestTag.Blacklisted}">
                    <Setter Property="Background" Value="{StaticResource DangerSoftBrush}" />
                    <Setter Property="TextElement.Foreground" Value="{StaticResource DangerBrush}" />
                </DataTrigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="GuestRowItem" TargetType="ListBoxItem">
            <Setter Property="Margin" Value="0,0,0,8" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ListBoxItem">
                        <Border x:Name="bd" Background="{StaticResource CardBrush}"
                                BorderBrush="{StaticResource LineBrush}" BorderThickness="1"
                                CornerRadius="4" Padding="10,8" Cursor="Hand">
                            <ContentPresenter />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="bd" Property="Background" Value="#F5F6F2" />
                            </Trigger>
                            <Trigger Property="IsSelected" Value="True">
                                <Setter TargetName="bd" Property="Background" Value="{StaticResource BrandSoftBrush}" />
                                <Setter TargetName="bd" Property="BorderBrush" Value="{StaticResource BrandBrush}" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </UserControl.Resources>

    <Grid Margin="24,18,24,24">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <TextBlock Grid.Row="0" Text="Khách hàng" Style="{StaticResource PageTitleText}" Margin="0,0,0,12" />

        <DockPanel Grid.Row="1" Margin="0,0,0,12">
            <Button DockPanel.Dock="Right" Content="+ Thêm khách" Style="{StaticResource PrimaryButton}"
                    Padding="16,8" Command="{Binding AddCommand}" />
            <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                <TextBlock Text="Tìm:" Style="{StaticResource CaptionText}" FontSize="12.5"
                           VerticalAlignment="Center" Margin="2,0,8,0" />
                <TextBox Width="260" VerticalAlignment="Center"
                         Text="{Binding SearchText, UpdateSourceTrigger=PropertyChanged, Delay=300}"
                         ToolTip="Tìm theo tên, SĐT, CCCD hoặc email" />
                <TextBlock Text="{Binding TotalText}" Style="{StaticResource CaptionText}"
                           FontSize="12.5" VerticalAlignment="Center" Margin="14,0,0,0" />
            </StackPanel>
        </DockPanel>

        <hc:LoadingCircle Grid.Row="2" Width="34" Height="34"
                          Foreground="{StaticResource BrandBrush}"
                          Visibility="{Binding IsLoading, Converter={StaticResource BoolToVis}}" />
        <TextBlock Grid.Row="2" Text="Không có khách hàng nào khớp — thử từ khoá khác hoặc thêm khách mới."
                   Style="{StaticResource CaptionText}" FontSize="13"
                   HorizontalAlignment="Center" VerticalAlignment="Center"
                   Visibility="{Binding IsEmpty, Converter={StaticResource BoolToVis}}" />

        <Grid Grid.Row="2">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="1.4*" />
                <ColumnDefinition Width="16" />
                <ColumnDefinition Width="1*" />
            </Grid.ColumnDefinitions>

            <ListBox Grid.Column="0" ItemsSource="{Binding Rows}" SelectedItem="{Binding SelectedRow}"
                     ItemContainerStyle="{StaticResource GuestRowItem}"
                     Background="Transparent" BorderThickness="0"
                     ScrollViewer.HorizontalScrollBarVisibility="Disabled">
                <ListBox.ItemTemplate>
                    <DataTemplate>
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            <!-- Avatar chữ cái (hình tròn - ngoại lệ hệ bo góc) -->
                            <Border Grid.Column="0" Width="40" Height="40" CornerRadius="999"
                                    Background="{StaticResource BrandSoftBrush}">
                                <TextBlock Text="{Binding Initial}" FontWeight="Bold" FontSize="15"
                                           Foreground="{StaticResource BrandDarkBrush}"
                                           HorizontalAlignment="Center" VerticalAlignment="Center" />
                            </Border>
                            <StackPanel Grid.Column="1" Margin="12,0,10,0" VerticalAlignment="Center">
                                <TextBlock Text="{Binding Guest.FullName}" FontSize="14" FontWeight="SemiBold" />
                                <TextBlock Text="{Binding SubText}" Style="{StaticResource CaptionText}"
                                           FontSize="11.5" TextTrimming="CharacterEllipsis" Margin="0,2,0,0" />
                            </StackPanel>
                            <Border Grid.Column="2" Style="{StaticResource GuestTagBadge}"
                                    VerticalAlignment="Center" Margin="0,0,12,0"
                                    Visibility="{Binding HasTag, Converter={StaticResource BoolToVis}}">
                                <TextBlock Text="{Binding TagText}" />
                            </Border>
                            <TextBlock Grid.Column="3" Text="{Binding ReservationText}"
                                       Style="{StaticResource CaptionText}" FontSize="12"
                                       VerticalAlignment="Center" />
                        </Grid>
                    </DataTemplate>
                </ListBox.ItemTemplate>
            </ListBox>

            <Border Grid.Column="2" Style="{StaticResource Card}" Effect="{StaticResource SoftShadow}"
                    VerticalAlignment="Top">
                <Grid>
                    <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center" Margin="20,50"
                                TextElement.Foreground="{StaticResource InkSoftBrush}">
                        <StackPanel.Style>
                            <Style TargetType="StackPanel">
                                <Setter Property="Visibility" Value="Visible" />
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding HasSelection}" Value="True">
                                        <Setter Property="Visibility" Value="Collapsed" />
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </StackPanel.Style>
                        <TextBlock Text="&#xE77B;" Style="{StaticResource IconText}" FontSize="28" HorizontalAlignment="Center" />
                        <TextBlock Text="Chọn một khách để xem chi tiết" Style="{StaticResource CaptionText}"
                                   FontSize="12.5" HorizontalAlignment="Center" Margin="0,10,0,0" />
                    </StackPanel>

                    <StackPanel DataContext="{Binding SelectedRow}">
                        <StackPanel.Style>
                            <Style TargetType="StackPanel">
                                <Setter Property="Visibility" Value="Collapsed" />
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding DataContext.HasSelection, RelativeSource={RelativeSource AncestorType=UserControl}}" Value="True">
                                        <Setter Property="Visibility" Value="Visible" />
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </StackPanel.Style>

                        <StackPanel Orientation="Horizontal">
                            <Border Width="52" Height="52" CornerRadius="999" Background="{StaticResource BrandSoftBrush}">
                                <TextBlock Text="{Binding Initial}" FontWeight="Bold" FontSize="20"
                                           Foreground="{StaticResource BrandDarkBrush}"
                                           HorizontalAlignment="Center" VerticalAlignment="Center" />
                            </Border>
                            <StackPanel Margin="13,0,0,0" VerticalAlignment="Center">
                                <TextBlock Text="{Binding Guest.FullName}" Style="{StaticResource SectionTitleText}" FontSize="17" />
                                <Border Style="{StaticResource GuestTagBadge}" HorizontalAlignment="Left" Margin="0,4,0,0"
                                        Visibility="{Binding HasTag, Converter={StaticResource BoolToVis}}">
                                    <TextBlock Text="{Binding TagText}" />
                                </Border>
                            </StackPanel>
                        </StackPanel>

                        <Border Height="1" Background="{StaticResource LineBrush}" Margin="0,14,0,12" />
                        <UniformGrid Columns="2">
                            <StackPanel Margin="0,0,0,10">
                                <TextBlock Text="SỐ ĐIỆN THOẠI" Style="{StaticResource FieldLabel}" />
                                <TextBlock Text="{Binding Guest.PhoneNumber}" FontWeight="SemiBold" />
                            </StackPanel>
                            <StackPanel Margin="0,0,0,10">
                                <TextBlock Text="CCCD / CMND" Style="{StaticResource FieldLabel}" />
                                <TextBlock Text="{Binding Guest.IdentityNumber}" FontWeight="SemiBold" />
                            </StackPanel>
                            <StackPanel Margin="0,0,0,10">
                                <TextBlock Text="EMAIL" Style="{StaticResource FieldLabel}" />
                                <TextBlock Text="{Binding EmailText}" FontWeight="SemiBold"
                                           TextTrimming="CharacterEllipsis" />
                            </StackPanel>
                            <StackPanel Margin="0,0,0,10">
                                <TextBlock Text="LỊCH SỬ" Style="{StaticResource FieldLabel}" />
                                <TextBlock Text="{Binding ReservationText}" FontWeight="SemiBold" />
                            </StackPanel>
                        </UniformGrid>

                        <TextBlock Text="GHI CHÚ PHÂN LOẠI" Style="{StaticResource FieldLabel}" Margin="0,2,0,3"
                                   Visibility="{Binding HasTagNote, Converter={StaticResource BoolToVis}}" />
                        <TextBlock Text="{Binding TagNote}" Style="{StaticResource CaptionText}" FontSize="12"
                                   TextWrapping="Wrap"
                                   Visibility="{Binding HasTagNote, Converter={StaticResource BoolToVis}}" />

                        <Border Height="1" Background="{StaticResource LineBrush}" Margin="0,16,0,14" />
                        <Button Content="Sửa thông tin" Style="{StaticResource PrimaryButton}"
                                Padding="16,7" HorizontalAlignment="Left"
                                Command="{Binding DataContext.EditCommand,
                                          RelativeSource={RelativeSource AncestorType=UserControl}}" />
                    </StackPanel>
                </Grid>
            </Border>
        </Grid>
    </Grid>
</UserControl>
