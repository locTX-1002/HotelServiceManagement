<UserControl x:Class="FUHotelManagementWPF.Views.Guests.GuestListView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:hc="https://handyorg.github.io/handycontrol">
    <Grid Margin="24,18,24,24">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <TextBlock Grid.Row="0" Text="Khách hàng" Style="{StaticResource PageTitleText}"
                   Margin="0,0,0,12" />

        <!-- Toolbar: tim kiem + nut them -->
        <DockPanel Grid.Row="1" Margin="0,0,0,12">
            <Button DockPanel.Dock="Right" Content="+ Thêm khách"
                    Style="{StaticResource PrimaryButton}" Padding="16,8"
                    Command="{Binding AddCommand}" />
            <StackPanel Orientation="Horizontal">
                <TextBlock Text="Tìm:" Style="{StaticResource CaptionText}" FontSize="12.5"
                           VerticalAlignment="Center" Margin="2,0,8,0" />
                <TextBox Width="280"
                         Text="{Binding SearchText, UpdateSourceTrigger=PropertyChanged}"
                         ToolTip="Tìm theo tên, số điện thoại, email hoặc CCCD" />
            </StackPanel>
        </DockPanel>

        <Grid Grid.Row="2">
            <DataGrid x:Name="GuestsGrid" ItemsSource="{Binding RowsView}"
                      AutoGenerateColumns="False" IsReadOnly="True"
                      CanUserAddRows="False" HeadersVisibility="Column"
                      SelectionMode="Single" SelectionUnit="FullRow"
                      RowHeight="46" GridLinesVisibility="None"
                      Background="Transparent" BorderThickness="0">
                <DataGrid.InputBindings>
                    <!-- Double-click 1 dong = mo sua nhanh -->
                    <MouseBinding Gesture="LeftDoubleClick"
                                  Command="{Binding EditCommand}"
                                  CommandParameter="{Binding SelectedItem, ElementName=GuestsGrid}" />
                </DataGrid.InputBindings>
                <DataGrid.Columns>
                    <DataGridTextColumn Header="Họ tên" Binding="{Binding Guest.FullName}" Width="*" />
                    <DataGridTextColumn Header="Điện thoại" Binding="{Binding Guest.PhoneNumber}" Width="130" />
                    <DataGridTextColumn Header="Email" Binding="{Binding EmailText}" Width="200" />
                    <DataGridTextColumn Header="CCCD/CMND" Binding="{Binding IdentityText}" Width="130" />
                    <DataGridTemplateColumn Header="Nhãn" Width="110">
                        <DataGridTemplateColumn.CellTemplate>
                            <DataTemplate>
                                <!-- Badge doi mau theo nhan: VIP vang, Han che do, Thuong xam -->
                                <Border VerticalAlignment="Center">
                                    <Border.Style>
                                        <Style TargetType="Border" BasedOn="{StaticResource BadgeNeutral}">
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding TagText}" Value="VIP">
                                                    <Setter Property="Background" Value="{StaticResource WarningSoftBrush}" />
                                                    <Setter Property="TextElement.Foreground" Value="{StaticResource WarningBrush}" />
                                                </DataTrigger>
                                                <DataTrigger Binding="{Binding TagText}" Value="Hạn chế">
                                                    <Setter Property="Background" Value="{StaticResource DangerSoftBrush}" />
                                                    <Setter Property="TextElement.Foreground" Value="{StaticResource DangerBrush}" />
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </Border.Style>
                                    <TextBlock Text="{Binding TagText}" ToolTip="{Binding Guest.TagNote}" />
                                </Border>
                            </DataTemplate>
                        </DataGridTemplateColumn.CellTemplate>
                    </DataGridTemplateColumn>
                    <DataGridTemplateColumn Header="" Width="150">
                        <DataGridTemplateColumn.CellTemplate>
                            <DataTemplate>
                                <StackPanel Orientation="Horizontal">
                                    <Button Content="Sửa" Style="{StaticResource GhostButton}" Padding="12,5"
                                            Command="{Binding DataContext.EditCommand,
                                                      RelativeSource={RelativeSource AncestorType=DataGrid}}"
                                            CommandParameter="{Binding}" />
                                    <Button Content="Xoá" Style="{StaticResource GhostButton}" Padding="12,5"
                                            Margin="6,0,0,0" Foreground="{StaticResource DangerBrush}"
                                            Command="{Binding DataContext.DeleteCommand,
                                                      RelativeSource={RelativeSource AncestorType=DataGrid}}"
                                            CommandParameter="{Binding}" />
                                </StackPanel>
                            </DataTemplate>
                        </DataGridTemplateColumn.CellTemplate>
                    </DataGridTemplateColumn>
                </DataGrid.Columns>
            </DataGrid>

            <!-- Empty state: chi hien khi da tai xong va khong co dong nao -->
            <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center"
                        Visibility="{Binding IsEmpty, Converter={StaticResource BoolToVis}}">
                <TextBlock Text="&#xE716;" Style="{StaticResource IconText}" FontSize="34"
                           Foreground="{StaticResource InkSoftBrush}" HorizontalAlignment="Center" />
                <TextBlock Text="Chưa có khách hàng nào" Style="{StaticResource BodyText}"
                           Margin="0,10,0,4" HorizontalAlignment="Center" />
                <TextBlock Text="Bấm  + Thêm khách  để tạo hồ sơ đầu tiên."
                           Style="{StaticResource CaptionText}" HorizontalAlignment="Center" />
            </StackPanel>

            <!-- Error state: loi that (mat SQL...) - co nut thu lai -->
            <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center"
                        Visibility="{Binding LoadFailed, Converter={StaticResource BoolToVis}}">
                <TextBlock Text="&#xE7BA;" Style="{StaticResource IconText}" FontSize="34"
                           Foreground="{StaticResource DangerBrush}" HorizontalAlignment="Center" />
                <TextBlock Text="Không tải được danh sách khách hàng" Style="{StaticResource BodyText}"
                           Margin="0,10,0,10" HorizontalAlignment="Center" />
                <Button Content="Thử lại" Style="{StaticResource PrimaryButton}" Padding="18,8"
                        HorizontalAlignment="Center" Command="{Binding ReloadCommand}" />
            </StackPanel>

            <!-- Loading -->
            <hc:LoadingCircle VerticalAlignment="Center" HorizontalAlignment="Center"
                              Visibility="{Binding IsLoading, Converter={StaticResource BoolToVis}}" />
        </Grid>
    </Grid>
</UserControl>
