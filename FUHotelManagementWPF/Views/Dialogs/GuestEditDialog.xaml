<Window x:Class="FUHotelManagementWPF.Views.Dialogs.GuestEditDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="{Binding Title}"
        Width="460" SizeToContent="Height"
        WindowStartupLocation="CenterOwner" ResizeMode="NoResize"
        ShowInTaskbar="False"
        Style="{StaticResource BaseWindow}">
    <!-- Double-bezel: card noi tren nen Surface (quy uoc giao dien) -->
    <Border Style="{StaticResource Card}" Effect="{StaticResource SoftShadowLarge}"
            Margin="16" Padding="26,22">
        <StackPanel>

        <TextBlock Text="HỌ TÊN" Style="{StaticResource FieldLabel}" />
        <TextBox Text="{Binding FullName, UpdateSourceTrigger=PropertyChanged, ValidatesOnNotifyDataErrors=True}" />

        <Grid Margin="0,14,0,0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="14" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>
            <StackPanel Grid.Column="0">
                <TextBlock Text="SỐ ĐIỆN THOẠI" Style="{StaticResource FieldLabel}" />
                <TextBox Text="{Binding PhoneNumber, UpdateSourceTrigger=PropertyChanged, ValidatesOnNotifyDataErrors=True}" />
            </StackPanel>
            <StackPanel Grid.Column="2">
                <TextBlock Text="CCCD/CMND" Style="{StaticResource FieldLabel}" />
                <TextBox Text="{Binding IdentityNumber, UpdateSourceTrigger=PropertyChanged, ValidatesOnNotifyDataErrors=True}"
                         ToolTip="Có thể để trống khi tạo hồ sơ tạm; phải bổ sung trước khi check-in" />
            </StackPanel>
        </Grid>

        <TextBlock Text="EMAIL (KHÔNG BẮT BUỘC)" Style="{StaticResource FieldLabel}" Margin="0,14,0,0" />
        <TextBox Text="{Binding Email, UpdateSourceTrigger=PropertyChanged, ValidatesOnNotifyDataErrors=True}" />

        <TextBlock Text="NHÃN KHÁCH" Style="{StaticResource FieldLabel}" Margin="0,14,0,5" />
        <ComboBox ItemsSource="{Binding TagOptions}"
                  SelectedItem="{Binding SelectedTag}"
                  DisplayMemberPath="Label" />

        <!-- Ghi chu nhan: chi hien khi khach duoc gan VIP/Han che -->
        <StackPanel Visibility="{Binding ShowTagNote, Converter={StaticResource BoolToVis}}">
            <TextBlock Text="GHI CHÚ NHÃN" Style="{StaticResource FieldLabel}" Margin="0,14,0,0" />
            <TextBox Text="{Binding TagNote, UpdateSourceTrigger=PropertyChanged}"
                     ToolTip="Lý do gắn nhãn, ví dụ: khách quen 10 lần / từng gây rối" />
        </StackPanel>

        <!-- Banner loi nghiep vu tu service -->
        <Border Margin="0,14,0,0" CornerRadius="8" Padding="10,8"
                Background="{StaticResource DangerSoftBrush}">
            <Border.Style>
                <Style TargetType="Border">
                    <Style.Triggers>
                        <DataTrigger Binding="{Binding ErrorMessage}" Value="">
                            <Setter Property="Visibility" Value="Collapsed" />
                        </DataTrigger>
                        <DataTrigger Binding="{Binding ErrorMessage}" Value="{x:Null}">
                            <Setter Property="Visibility" Value="Collapsed" />
                        </DataTrigger>
                    </Style.Triggers>
                </Style>
            </Border.Style>
            <StackPanel Orientation="Horizontal">
                <TextBlock Text="&#xE7BA;" Style="{StaticResource IconText}"
                           Foreground="{StaticResource DangerBrush}" Margin="0,2,8,0"
                           VerticalAlignment="Top" />
                <TextBlock Text="{Binding ErrorMessage}" Foreground="{StaticResource DangerBrush}"
                           TextWrapping="Wrap" MaxWidth="350" />
            </StackPanel>
        </Border>

        <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,20,0,0">
            <Button Content="Huỷ" Style="{StaticResource GhostButton}" IsCancel="True" />
            <Button Content="Lưu" Style="{StaticResource PrimaryButton}" Margin="10,0,0,0"
                    MinWidth="96" IsDefault="True"
                    Command="{Binding SaveCommand}" />
        </StackPanel>
        </StackPanel>
    </Border>
</Window>
