<Window x:Class="FUHotelManagementWPF.Views.Dialogs.GuestEditDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="{Binding Title}"
        Width="460" SizeToContent="Height"
        WindowStartupLocation="CenterOwner" ResizeMode="NoResize"
        ShowInTaskbar="False"
        Style="{StaticResource BaseWindow}">
    <Border Style="{StaticResource Card}" Effect="{StaticResource SoftShadowLarge}" Margin="14" Padding="0">
        <StackPanel>
            <Border CornerRadius="4,4,0,0" Padding="20,15">
                <Border.Style>
                    <Style TargetType="Border">
                        <Setter Property="Background" Value="{StaticResource BrandSoftBrush}" />
                        <Style.Triggers>
                            <DataTrigger Binding="{Binding IsEdit}" Value="True">
                                <Setter Property="Background" Value="{StaticResource WarningSoftBrush}" />
                            </DataTrigger>
                        </Style.Triggers>
                    </Style>
                </Border.Style>
                <StackPanel>
                    <TextBlock Text="{Binding Title}" Style="{StaticResource SectionTitleText}" FontSize="16.5" />
                    <TextBlock Text="{Binding Subtitle}" Style="{StaticResource CaptionText}" FontSize="11.5" Margin="0,2,0,0" />
                </StackPanel>
            </Border>

            <StackPanel Margin="20,16,20,18">
                <TextBlock Text="HỌ TÊN" Style="{StaticResource FieldLabel}" />
                <TextBox Text="{Binding FullName, UpdateSourceTrigger=PropertyChanged, ValidatesOnNotifyDataErrors=True}" />

                <Grid Margin="0,13,0,0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="12" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>
                    <StackPanel Grid.Column="0">
                        <TextBlock Text="SỐ ĐIỆN THOẠI" Style="{StaticResource FieldLabel}" />
                        <TextBox Text="{Binding Phone, UpdateSourceTrigger=PropertyChanged, ValidatesOnNotifyDataErrors=True}" />
                    </StackPanel>
                    <StackPanel Grid.Column="2">
                        <TextBlock Text="CCCD / CMND" Style="{StaticResource FieldLabel}" />
                        <TextBox Text="{Binding IdentityNumber, UpdateSourceTrigger=PropertyChanged, ValidatesOnNotifyDataErrors=True}" />
                    </StackPanel>
                </Grid>

                <TextBlock Text="EMAIL (TUỲ CHỌN)" Style="{StaticResource FieldLabel}" Margin="0,13,0,5" />
                <TextBox Text="{Binding Email, UpdateSourceTrigger=PropertyChanged}" />

                <!-- Phân loại: chỉ hiện khi sửa (khách mới luôn bắt đầu Bình thường) -->
                <StackPanel Visibility="{Binding IsEdit, Converter={StaticResource BoolToVis}}">
                    <TextBlock Text="PHÂN LOẠI KHÁCH" Style="{StaticResource FieldLabel}" Margin="0,13,0,5" />
                    <ComboBox ItemsSource="{Binding TagOptions}" SelectedItem="{Binding SelectedTag}"
                              DisplayMemberPath="Label" />
                    <StackPanel Visibility="{Binding ShowTagNote, Converter={StaticResource BoolToVis}}">
                        <TextBlock Text="GHI CHÚ PHÂN LOẠI" Style="{StaticResource FieldLabel}" Margin="0,12,0,5" />
                        <TextBox Text="{Binding TagNote, UpdateSourceTrigger=PropertyChanged}"
                                 Height="52" TextWrapping="Wrap" AcceptsReturn="True"
                                 ToolTip="{Binding TagNotePlaceholder}" />
                    </StackPanel>
                </StackPanel>

                <Border Margin="0,14,0,0" CornerRadius="4" Padding="10,8" Background="{StaticResource DangerSoftBrush}">
                    <Border.Style>
                        <Style TargetType="Border">
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding ErrorMessage}" Value=""><Setter Property="Visibility" Value="Collapsed" /></DataTrigger>
                                <DataTrigger Binding="{Binding ErrorMessage}" Value="{x:Null}"><Setter Property="Visibility" Value="Collapsed" /></DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </Border.Style>
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="&#xE7BA;" Style="{StaticResource IconText}"
                                   Foreground="{StaticResource DangerBrush}" Margin="0,2,8,0" VerticalAlignment="Top" />
                        <TextBlock Text="{Binding ErrorMessage}" Foreground="{StaticResource DangerBrush}"
                                   TextWrapping="Wrap" MaxWidth="340" />
                    </StackPanel>
                </Border>

                <Border Height="1" Background="{StaticResource LineBrush}" Margin="0,16,0,0" />
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,14,0,0">
                    <Button Content="Huỷ" Style="{StaticResource GhostButton}" IsCancel="True" />
                    <Button Content="Lưu" Style="{StaticResource PrimaryButton}" Margin="10,0,0,0"
                            MinWidth="96" IsDefault="True" Command="{Binding SaveCommand}" />
                </StackPanel>
            </StackPanel>
        </StackPanel>
    </Border>
</Window>
