<Window x:Class="FUHotelManagementWPF.Views.Dialogs.RoomEditDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:hc="https://handyorg.github.io/handycontrol"
        Title="{Binding Title}"
        Width="460" SizeToContent="Height"
        WindowStartupLocation="CenterOwner" ResizeMode="NoResize"
        ShowInTaskbar="False"
        Style="{StaticResource BaseWindow}">
    <Border Style="{StaticResource Card}" Effect="{StaticResource SoftShadowLarge}"
            Margin="14" Padding="0">
        <StackPanel>

            <!-- Header: XANH = them moi, VANG = dang sua (phan biet ngay bang mau) -->
            <Border CornerRadius="11,11,0,0" Padding="20,15">
                <Border.Style>
                    <Style TargetType="Border">
                        <Setter Property="Background" Value="{StaticResource BrandSoftBrush}" />
                        <Style.Triggers>
                            <DataTrigger Binding="{Binding IsEdit}" Value="True">
                                <Setter Property="Background" Value="{StaticResource WarningSoftBrush}" />
                            </DataTrigger>
                        </Style.Triggers>
                    </Style>
                </Border.Style>
                <StackPanel Orientation="Horizontal">
                    <Border Width="38" Height="38" CornerRadius="999">
                        <Border.Style>
                            <Style TargetType="Border">
                                <Setter Property="Background" Value="{StaticResource BrandBrush}" />
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding IsEdit}" Value="True">
                                        <Setter Property="Background" Value="{StaticResource WarningBrush}" />
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </Border.Style>
                        <TextBlock Text="{Binding HeaderIcon}" Style="{StaticResource IconText}"
                                   FontSize="15" Foreground="White"
                                   HorizontalAlignment="Center" VerticalAlignment="Center" />
                    </Border>
                    <StackPanel Margin="13,0,0,0" VerticalAlignment="Center">
                        <TextBlock Text="{Binding Title}" Style="{StaticResource SectionTitleText}"
                                   FontSize="16.5" />
                        <TextBlock Text="{Binding Subtitle}" Style="{StaticResource CaptionText}"
                                   FontSize="11.5" TextWrapping="Wrap" MaxWidth="320"
                                   Margin="0,2,0,0" />
                    </StackPanel>
                </StackPanel>
            </Border>

            <!-- Anh xem truoc: doi loai phong la anh doi theo; BAM vao de chon anh tu may -->
            <Border Height="128" Margin="20,16,20,0" CornerRadius="10" Cursor="Hand"
                    ToolTip="Bấm để chọn ảnh khác từ máy của bạn (áp cho cả loại phòng)">
                <Border.Background>
                    <ImageBrush ImageSource="{Binding PreviewImage}" Stretch="UniformToFill" />
                </Border.Background>
                <Border.InputBindings>
                    <MouseBinding Gesture="LeftClick" Command="{Binding ChooseImageCommand}" />
                </Border.InputBindings>
                <Border CornerRadius="12" Background="#A6000000" Padding="10,4"
                        HorizontalAlignment="Left" VerticalAlignment="Bottom" Margin="10,0,0,10">
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="&#xE722;" Style="{StaticResource IconText}" FontSize="11"
                                   Foreground="White" Margin="0,0,6,0" />
                        <TextBlock Text="Bấm để đổi ảnh" Foreground="White" FontSize="10.5" />
                    </StackPanel>
                </Border>
            </Border>

            <StackPanel Margin="20,16,20,18">
                <TextBlock Text="SỐ PHÒNG" Style="{StaticResource FieldLabel}" />
                <TextBox Text="{Binding RoomNumber, UpdateSourceTrigger=PropertyChanged, ValidatesOnNotifyDataErrors=True}" />

                <Grid Margin="0,13,0,0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="13" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>
                    <StackPanel Grid.Column="0">
                        <TextBlock Text="TẦNG" Style="{StaticResource FieldLabel}" />
                        <!-- Chon so, khong nhap tay -->
                        <hc:NumericUpDown Minimum="1" Maximum="60" Increment="1"
                                          Value="{Binding FloorValue}" />
                    </StackPanel>
                    <StackPanel Grid.Column="2">
                        <TextBlock Text="TRẠNG THÁI" Style="{StaticResource FieldLabel}" />
                        <ComboBox ItemsSource="{Binding StatusOptions}"
                                  SelectedItem="{Binding SelectedStatus}"
                                  DisplayMemberPath="Label" />
                    </StackPanel>
                </Grid>

                <TextBlock Text="LOẠI PHÒNG" Style="{StaticResource FieldLabel}" Margin="0,13,0,5" />
                <ComboBox ItemsSource="{Binding RoomTypes}" SelectedItem="{Binding SelectedRoomType}">
                    <ComboBox.ItemTemplate>
                        <DataTemplate>
                            <TextBlock>
                                <Run Text="{Binding TypeName, Mode=OneWay}" FontWeight="SemiBold" />
                                <Run Text=" · " Foreground="{StaticResource InkSoftBrush}" />
                                <Run Text="{Binding Capacity, Mode=OneWay}" /><Run Text=" khách · " />
                                <Run Text="{Binding BasePrice, Mode=OneWay, StringFormat={}{0:N0}}" /><Run Text=" đ/đêm" />
                            </TextBlock>
                        </DataTemplate>
                    </ComboBox.ItemTemplate>
                </ComboBox>

                <CheckBox Content="Đang sử dụng" IsChecked="{Binding IsActive}" Margin="0,14,0,0" />

                <!-- Banner loi nghiep vu tu service -->
                <Border Margin="0,13,0,0" CornerRadius="8" Padding="10,8"
                        Background="{StaticResource DangerSoftBrush}">
                    <Border.Style>
                        <Style TargetType="Border">
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding ErrorMessage}" Value="">
                                    <Setter Property="Visibility" Value="Collapsed" />
                                </DataTrigger>
                                <DataTrigger Binding="{Binding ErrorMessage}" Value="{x:Null}">
                                    <Setter Property="Visibility" Value="Collapsed" />
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </Border.Style>
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="&#xE7BA;" Style="{StaticResource IconText}"
                                   Foreground="{StaticResource DangerBrush}" Margin="0,2,8,0"
                                   VerticalAlignment="Top" />
                        <TextBlock Text="{Binding ErrorMessage}" Foreground="{StaticResource DangerBrush}"
                                   TextWrapping="Wrap" MaxWidth="340" />
                    </StackPanel>
                </Border>

                <Border Height="1" Background="{StaticResource LineBrush}" Margin="0,16,0,0" />
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,14,0,0">
                    <Button Content="Huỷ" Style="{StaticResource GhostButton}" IsCancel="True" />
                    <Button Content="Lưu" Style="{StaticResource PrimaryButton}" Margin="10,0,0,0"
                            MinWidth="96" IsDefault="True"
                            Command="{Binding SaveCommand}" />
                </StackPanel>
            </StackPanel>
        </StackPanel>
    </Border>
</Window>
