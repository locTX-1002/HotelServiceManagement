<Window x:Class="FUHotelManagementWPF.Views.Dialogs.ConfirmDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Xác nhận"
        Width="440" SizeToContent="Height"
        WindowStartupLocation="CenterOwner" ResizeMode="NoResize"
        WindowStyle="None" AllowsTransparency="True" Background="Transparent"
        ShowInTaskbar="False">
    <Border Background="{StaticResource CardBrush}" CornerRadius="4" Margin="14"
            BorderBrush="{StaticResource LineBrush}" BorderThickness="1"
            Effect="{StaticResource SoftShadowLarge}">
        <StackPanel>
            <!-- Dai mau tren dinh: do cho viec khong lui lai duoc, xanh reu cho viec thuong -->
            <Border x:Name="AccentBar" Height="4" CornerRadius="4,4,0,0"
                    Background="{StaticResource BrandBrush}" />

            <StackPanel Margin="24,20,24,0">
                <TextBlock x:Name="TitleText" Style="{StaticResource SectionTitleText}" FontSize="17"
                           TextWrapping="Wrap" />
                <TextBlock x:Name="MessageText" Style="{StaticResource BodyText}" FontSize="13"
                           TextWrapping="Wrap" Margin="0,10,0,0" LineHeight="20" />
                <Border x:Name="NoteBox" Background="{StaticResource SurfaceAltBrush}" CornerRadius="4"
                        Padding="12,9" Margin="0,14,0,0" Visibility="Collapsed">
                    <TextBlock x:Name="NoteText" Style="{StaticResource CaptionText}" FontSize="12"
                               TextWrapping="Wrap" LineHeight="18" />
                </Border>
            </StackPanel>

            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Margin="24,22,24,20">
                <Button x:Name="CancelButton" Content="Để sau" Style="{StaticResource GhostButton}"
                        Padding="18,8" IsCancel="True" Click="Cancel_Click" />
                <Button x:Name="OkButton" Content="Xác nhận" Style="{StaticResource PrimaryButton}"
                        Padding="20,8" MinWidth="120" Margin="10,0,0,0" IsDefault="True"
                        Click="Ok_Click" />
            </StackPanel>
        </StackPanel>
    </Border>
</Window>
