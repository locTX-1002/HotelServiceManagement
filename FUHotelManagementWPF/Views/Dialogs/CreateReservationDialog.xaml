<Window x:Class="FUHotelManagementWPF.Views.Dialogs.CreateReservationDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:hc="https://handyorg.github.io/handycontrol"
        Title="{Binding Title}"
        Width="520" MaxHeight="720" SizeToContent="Height"
        WindowStartupLocation="CenterOwner" ResizeMode="NoResize"
        ShowInTaskbar="False"
        Style="{StaticResource BaseWindow}">
    <Border Style="{StaticResource Card}" Effect="{StaticResource SoftShadowLarge}" Margin="14" Padding="0">
        <StackPanel>
            <!-- Header -->
            <Border CornerRadius="4,4,0,0" Padding="20,15">
                <Border.Style>
                    <Style TargetType="Border">
                        <Setter Property="Background" Value="{StaticResource BrandSoftBrush}" />
                        <Style.Triggers>
                            <DataTrigger Binding="{Binding IsEdit}" Value="True">
                                <Setter Property="Background" Value="{StaticResource WarningSoftBrush}" />
                            </DataTrigger>
                        </Style.Triggers>
                    </Style>
                </Border.Style>
                <StackPanel>
                    <TextBlock Text="{Binding Title}" Style="{StaticResource SectionTitleText}" FontSize="16.5" />
                    <TextBlock Text="{Binding Subtitle}" Style="{StaticResource CaptionText}" FontSize="11.5" Margin="0,2,0,0" />
                </StackPanel>
            </Border>

            <ScrollViewer VerticalScrollBarVisibility="Auto" MaxHeight="560">
                <StackPanel Margin="20,16,20,18">
                    <!-- 1. Khách -->
                    <TextBlock Text="1 · KHÁCH HÀNG (CCCD HOẶC SĐT)" Style="{StaticResource FieldLabel}" />
                    <DockPanel>
                        <Button DockPanel.Dock="Right" Content="Tìm" Style="{StaticResource GhostButton}"
                                Padding="16,8" Margin="8,0,0,0" Command="{Binding FindGuestCommand}"
                                IsEnabled="{Binding CanEditGuest}" />
                        <TextBox Text="{Binding GuestKeyword, UpdateSourceTrigger=PropertyChanged}"
                                 IsReadOnly="{Binding IsEdit}" />
                    </DockPanel>

                    <!-- Khách khớp -->
                    <Border Margin="0,8,0,0" CornerRadius="4" Padding="10,8" Background="{StaticResource SuccessSoftBrush}"
                            Visibility="{Binding HasMatchedGuest, Converter={StaticResource BoolToVis}}">
                        <TextBlock Text="{Binding GuestInfoText}" Foreground="{StaticResource SuccessBrush}"
                                   FontWeight="SemiBold" TextWrapping="Wrap" />
                    </Border>
                    <!-- Cảnh báo blacklist -->
                    <Border Margin="0,8,0,0" CornerRadius="4" Padding="10,8" Background="{StaticResource DangerSoftBrush}"
                            Visibility="{Binding IsBlacklisted, Converter={StaticResource BoolToVis}}">
                        <TextBlock Text="⚠ Khách nằm trong danh sách cảnh báo. Cân nhắc trước khi đặt phòng."
                                   Foreground="{StaticResource DangerBrush}" TextWrapping="Wrap" />
                    </Border>

                    <!-- Form tạo khách mới -->
                    <StackPanel Margin="0,10,0,0" Visibility="{Binding ShowNewGuestFields, Converter={StaticResource BoolToVis}}">
                        <TextBlock Text="Khách mới — điền thông tin (CCCD lấy từ ô tìm ở trên):"
                                   Style="{StaticResource CaptionText}" Margin="0,0,0,6" />
                        <TextBox Text="{Binding NewFullName}" hc:InfoElement.Placeholder="Họ tên" Margin="0,0,0,6" />
                        <TextBox Text="{Binding NewPhone}" hc:InfoElement.Placeholder="Số điện thoại" Margin="0,0,0,6" />
                        <TextBox Text="{Binding NewEmail}" hc:InfoElement.Placeholder="Email (tuỳ chọn)" />
                    </StackPanel>

                    <!-- 2. Ngày -->
                    <TextBlock Text="2 · NGÀY NHẬN → TRẢ" Style="{StaticResource FieldLabel}" Margin="0,16,0,5" />
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="10" />
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="10" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <DatePicker Grid.Column="0" SelectedDate="{Binding CheckIn}" />
                        <DatePicker Grid.Column="2" SelectedDate="{Binding CheckOut}" />
                        <Button Grid.Column="4" Content="Tìm phòng trống" Style="{StaticResource GhostButton}"
                                Padding="14,8" Command="{Binding FindRoomsCommand}" />
                    </Grid>

                    <!-- 3. Phòng trống -->
                    <TextBlock Text="3 · CHỌN PHÒNG" Style="{StaticResource FieldLabel}" Margin="0,16,0,5"
                               Visibility="{Binding HasSearchedRooms, Converter={StaticResource BoolToVis}}" />
                    <ComboBox ItemsSource="{Binding AvailableRooms}" SelectedItem="{Binding SelectedRoom}"
                              Visibility="{Binding HasSearchedRooms, Converter={StaticResource BoolToVis}}">
                        <ComboBox.ItemTemplate>
                            <DataTemplate>
                                <TextBlock>
                                    <Run Text="{Binding RoomNumber, Mode=OneWay}" FontWeight="SemiBold" />
                                    <Run Text=" · " Foreground="{StaticResource InkSoftBrush}" />
                                    <Run Text="{Binding RoomType.TypeName, Mode=OneWay}" />
                                    <Run Text=" · " Foreground="{StaticResource InkSoftBrush}" />
                                    <Run Text="{Binding RoomType.Capacity, Mode=OneWay}" /><Run Text=" khách · " />
                                    <Run Text="{Binding RoomType.BasePrice, Mode=OneWay, StringFormat={}{0:N0}}" /><Run Text=" đ/đêm" />
                                </TextBlock>
                            </DataTemplate>
                        </ComboBox.ItemTemplate>
                    </ComboBox>

                    <!-- 4. Số khách + trạng thái -->
                    <Grid Margin="0,16,0,0" Visibility="{Binding HasSearchedRooms, Converter={StaticResource BoolToVis}}">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="12" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>
                        <StackPanel Grid.Column="0">
                            <TextBlock Text="SỐ KHÁCH" Style="{StaticResource FieldLabel}" />
                            <hc:NumericUpDown Minimum="1" Maximum="20" Value="{Binding NumberOfGuests}" />
                        </StackPanel>
                        <StackPanel Grid.Column="2">
                            <TextBlock Text="TRẠNG THÁI" Style="{StaticResource FieldLabel}" />
                            <ComboBox ItemsSource="{Binding StatusOptions}" SelectedItem="{Binding SelectedStatus}"
                                      DisplayMemberPath="Label" />
                        </StackPanel>
                    </Grid>

                    <TextBlock Text="YÊU CẦU ĐẶC BIỆT (TUỲ CHỌN)" Style="{StaticResource FieldLabel}" Margin="0,14,0,5" />
                    <TextBox Text="{Binding SpecialRequests}" Height="52" TextWrapping="Wrap"
                             AcceptsReturn="True" VerticalScrollBarVisibility="Auto" />

                    <!-- Banner lỗi -->
                    <Border Margin="0,14,0,0" CornerRadius="4" Padding="10,8" Background="{StaticResource DangerSoftBrush}">
                        <Border.Style>
                            <Style TargetType="Border">
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding ErrorMessage}" Value=""><Setter Property="Visibility" Value="Collapsed" /></DataTrigger>
                                    <DataTrigger Binding="{Binding ErrorMessage}" Value="{x:Null}"><Setter Property="Visibility" Value="Collapsed" /></DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </Border.Style>
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="&#xE7BA;" Style="{StaticResource IconText}"
                                       Foreground="{StaticResource DangerBrush}" Margin="0,2,8,0" VerticalAlignment="Top" />
                            <TextBlock Text="{Binding ErrorMessage}" Foreground="{StaticResource DangerBrush}"
                                       TextWrapping="Wrap" MaxWidth="400" />
                        </StackPanel>
                    </Border>

                    <Border Height="1" Background="{StaticResource LineBrush}" Margin="0,16,0,0" />
                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,14,0,0">
                        <Button Content="Huỷ" Style="{StaticResource GhostButton}" IsCancel="True" />
                        <Button Content="Lưu đặt phòng" Style="{StaticResource PrimaryButton}" Margin="10,0,0,0"
                                MinWidth="120" IsDefault="True" Command="{Binding SaveCommand}" />
                    </StackPanel>
                </StackPanel>
            </ScrollViewer>
        </StackPanel>
    </Border>
</Window>
