<Window x:Class="FUHotelManagementWPF.Views.Dialogs.SurchargeDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:hc="https://handyorg.github.io/handycontrol"
        Title="Phụ thu — kiểm đồ trong phòng"
        Width="540" MaxHeight="680" SizeToContent="Height"
        WindowStartupLocation="CenterOwner" ResizeMode="NoResize"
        ShowInTaskbar="False"
        Style="{StaticResource BaseWindow}">
    <Border Style="{StaticResource Card}" Effect="{StaticResource SoftShadowLarge}" Margin="14" Padding="0">
        <StackPanel>
            <Border Background="{StaticResource WarningSoftBrush}" CornerRadius="4,4,0,0" Padding="20,15">
                <StackPanel>
                    <TextBlock Text="Phụ thu — kiểm đồ trong phòng"
                               Style="{StaticResource SectionTitleText}" FontSize="16.5" />
                    <TextBlock Text="Ghi lại thứ khách làm hỏng hoặc mất trước khi cho trả phòng. Tiền này cộng vào hoá đơn."
                               Style="{StaticResource CaptionText}" FontSize="11.5" TextWrapping="Wrap"
                               Margin="0,3,0,0" />
                </StackPanel>
            </Border>

            <StackPanel Margin="20,16,20,18">
                <TextBlock Text="{Binding RoomText}" FontSize="14.5" FontWeight="SemiBold" />
                <TextBlock Text="{Binding GuestText}" Style="{StaticResource CaptionText}"
                           FontSize="12" Margin="0,2,0,0" />

                <!-- Chon muc trong bang gia roi ghi -->
                <TextBlock Text="THÊM DÒNG PHỤ THU" Style="{StaticResource FieldLabel}" Margin="0,16,0,5" />
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="10" />
                        <ColumnDefinition Width="86" />
                        <ColumnDefinition Width="10" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>
                    <ComboBox Grid.Column="0" ItemsSource="{Binding Items}" SelectedItem="{Binding SelectedItem}">
                        <ComboBox.ItemTemplate>
                            <DataTemplate>
                                <TextBlock>
                                    <Run Text="{Binding Name, Mode=OneWay}" />
                                    <Run Text=" · " Foreground="{StaticResource InkSoftBrush}" />
                                    <Run Text="{Binding UnitPrice, Mode=OneWay, StringFormat={}{0:N0}}" /><Run Text=" đ/" /><Run
                                    Text="{Binding Unit, Mode=OneWay}" />
                                </TextBlock>
                            </DataTemplate>
                        </ComboBox.ItemTemplate>
                    </ComboBox>
                    <hc:NumericUpDown Grid.Column="2" Minimum="1" Maximum="99" Value="{Binding Quantity}" />
                    <Button Grid.Column="4" Content="Ghi" Style="{StaticResource PrimaryButton}"
                            Padding="18,8" Command="{Binding AddCommand}" />
                </Grid>

                <Border CornerRadius="4" Padding="10,8" Margin="0,10,0,0"
                        Background="{StaticResource DangerSoftBrush}"
                        Visibility="{Binding HasError, Converter={StaticResource BoolToVis}}">
                    <TextBlock Text="{Binding ErrorMessage}" Foreground="{StaticResource DangerBrush}"
                               TextWrapping="Wrap" />
                </Border>

                <!-- Cac dong da ghi -->
                <TextBlock Text="ĐÃ GHI" Style="{StaticResource FieldLabel}" Margin="0,16,0,5" />
                <TextBlock Text="Chưa ghi dòng nào — phòng sạch sẽ thì bấm Xong."
                           Style="{StaticResource CaptionText}" FontSize="12" Margin="0,2,0,0"
                           Visibility="{Binding IsEmpty, Converter={StaticResource BoolToVis}}" />

                <ItemsControl ItemsSource="{Binding Lines}" MaxHeight="220">
                    <ItemsControl.Template>
                        <ControlTemplate TargetType="ItemsControl">
                            <ScrollViewer VerticalScrollBarVisibility="Auto">
                                <ItemsPresenter />
                            </ScrollViewer>
                        </ControlTemplate>
                    </ItemsControl.Template>
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <Border Background="{StaticResource CardBrush}" CornerRadius="4"
                                    BorderBrush="{StaticResource LineBrush}" BorderThickness="1"
                                    Padding="10,7" Margin="0,0,0,6">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="Auto" />
                                        <ColumnDefinition Width="Auto" />
                                        <ColumnDefinition Width="Auto" />
                                    </Grid.ColumnDefinitions>
                                    <StackPanel Grid.Column="0" VerticalAlignment="Center">
                                        <TextBlock Text="{Binding Name}" FontSize="13" />
                                        <TextBlock Text="{Binding UnitPriceText}" Style="{StaticResource CaptionText}"
                                                   FontSize="11" Margin="0,1,0,0" />
                                    </StackPanel>
                                    <TextBlock Grid.Column="1" Text="{Binding QuantityText}"
                                               Style="{StaticResource CaptionText}" FontSize="12"
                                               VerticalAlignment="Center" Margin="0,0,14,0" />
                                    <TextBlock Grid.Column="2" Text="{Binding SubtotalText}"
                                               FontWeight="SemiBold" VerticalAlignment="Center"
                                               Margin="0,0,10,0" />
                                    <Button Grid.Column="3" Content="Xoá" Style="{StaticResource GhostButton}"
                                            Padding="11,4" FontSize="11.5"
                                            Foreground="{StaticResource DangerBrush}"
                                            Command="{Binding DataContext.RemoveCommand,
                                                      RelativeSource={RelativeSource AncestorType=Window}}"
                                            CommandParameter="{Binding}" />
                                </Grid>
                            </Border>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>

                <Border Background="{StaticResource SurfaceAltBrush}" CornerRadius="4"
                        Padding="12,10" Margin="0,6,0,0">
                    <DockPanel>
                        <TextBlock DockPanel.Dock="Right" Text="{Binding TotalText}" FontSize="15"
                                   FontWeight="SemiBold" Foreground="{StaticResource BrandBrush}" />
                        <TextBlock Text="Tổng phụ thu" VerticalAlignment="Center" />
                    </DockPanel>
                </Border>

                <Border Height="1" Background="{StaticResource LineBrush}" Margin="0,16,0,0" />
                <Button Content="Xong" Style="{StaticResource PrimaryButton}" MinWidth="110"
                        HorizontalAlignment="Right" Margin="0,14,0,0" IsCancel="True" />
            </StackPanel>
        </StackPanel>
    </Border>
</Window>
