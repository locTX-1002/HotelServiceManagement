<Window x:Class="FUHotelManagementWPF.Views.Dialogs.RoomDetailDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="{Binding RoomTitle}"
        Width="620" SizeToContent="Height"
        WindowStartupLocation="CenterOwner" ResizeMode="NoResize"
        ShowInTaskbar="False"
        Style="{StaticResource BaseWindow}">
    <Window.Resources>
        <!-- Nut tron mui ten tren anh -->
        <Style x:Key="GalleryArrow" TargetType="Button">
            <Setter Property="Width" Value="38" />
            <Setter Property="Height" Value="38" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="VerticalAlignment" Value="Center" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="bd" CornerRadius="999" Background="#B3FFFFFF">
                            <TextBlock Text="{TemplateBinding Content}"
                                       FontFamily="Segoe MDL2 Assets" FontSize="13"
                                       Foreground="{StaticResource InkBrush}"
                                       HorizontalAlignment="Center" VerticalAlignment="Center" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="bd" Property="Background" Value="#F2FFFFFF" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Border Style="{StaticResource Card}" Effect="{StaticResource SoftShadowLarge}"
            Margin="16" Padding="0">
        <StackPanel>
            <!-- Gallery: anh lon + mui ten chuyen + bo dem -->
            <Border Height="300" CornerRadius="4,4,0,0">
                <Border.Background>
                    <ImageBrush ImageSource="{Binding CurrentImage}" Stretch="UniformToFill" />
                </Border.Background>
                <Grid>
                    <Button Style="{StaticResource GalleryArrow}" Content="&#xE76B;"
                            HorizontalAlignment="Left" Margin="12,0,0,0"
                            Command="{Binding PrevCommand}" />
                    <Button Style="{StaticResource GalleryArrow}" Content="&#xE76C;"
                            HorizontalAlignment="Right" Margin="0,0,12,0"
                            Command="{Binding NextCommand}" />
                    <Border CornerRadius="4" Background="#99000000" Padding="10,4"
                            HorizontalAlignment="Right" VerticalAlignment="Bottom"
                            Margin="0,0,12,10">
                        <TextBlock Text="{Binding Counter}" Foreground="White" FontSize="11.5" />
                    </Border>
                </Grid>
            </Border>

            <StackPanel Margin="24,18,24,22">
                <DockPanel>
                    <Border DockPanel.Dock="Right" Style="{StaticResource RoomStatusBadge}"
                            VerticalAlignment="Center">
                        <TextBlock Text="{Binding StatusText}" />
                    </Border>
                    <TextBlock Text="{Binding RoomTitle}" Style="{StaticResource PageTitleText}" />
                </DockPanel>
                <TextBlock Text="{Binding TypeName}" Style="{StaticResource CaptionText}"
                           FontSize="13" Margin="0,3,0,14" />

                <Border Height="1" Background="{StaticResource LineBrush}" Margin="0,0,0,14" />

                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>
                    <StackPanel Grid.Column="0">
                        <TextBlock Text="TẦNG" Style="{StaticResource FieldLabel}" />
                        <TextBlock Text="{Binding FloorText}" FontWeight="SemiBold" />
                    </StackPanel>
                    <StackPanel Grid.Column="1">
                        <TextBlock Text="SỨC CHỨA" Style="{StaticResource FieldLabel}" />
                        <TextBlock Text="{Binding CapacityText}" FontWeight="SemiBold" />
                    </StackPanel>
                    <StackPanel Grid.Column="2">
                        <TextBlock Text="GIÁ / ĐÊM" Style="{StaticResource FieldLabel}" />
                        <TextBlock Text="{Binding PriceText}" FontWeight="SemiBold" />
                    </StackPanel>
                    <StackPanel Grid.Column="3">
                        <TextBlock Text="TÌNH TRẠNG" Style="{StaticResource FieldLabel}" />
                        <TextBlock Text="{Binding ActiveText}" FontWeight="SemiBold" />
                    </StackPanel>
                </Grid>

                <TextBlock Text="{Binding TypeDescription}" Style="{StaticResource CaptionText}"
                           FontSize="12.5" TextWrapping="Wrap" Margin="0,14,0,0"
                           Visibility="{Binding HasDescription, Converter={StaticResource BoolToVis}}" />

                <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,18,0,0">
                    <Button Content="Đóng" Style="{StaticResource PrimaryButton}"
                            MinWidth="96" IsCancel="True" IsDefault="True" />
                </StackPanel>
            </StackPanel>
        </StackPanel>
    </Border>
</Window>
