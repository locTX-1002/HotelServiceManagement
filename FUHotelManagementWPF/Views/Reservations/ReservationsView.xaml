<UserControl x:Class="FUHotelManagementWPF.Views.Reservations.ReservationsView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:hc="https://handyorg.github.io/handycontrol"
             xmlns:enums="clr-namespace:BusinessObjects.Enums;assembly=BusinessObjects">
    <UserControl.Resources>
        <!-- Badge trạng thái đặt phòng theo Reservation.Status -->
        <Style x:Key="ResBadge" TargetType="Border" BasedOn="{StaticResource BadgeBase}">
            <Setter Property="Background" Value="{StaticResource SurfaceAltBrush}" />
            <Setter Property="TextElement.Foreground" Value="{StaticResource InkSoftBrush}" />
            <Style.Triggers>
                <DataTrigger Binding="{Binding Status}" Value="{x:Static enums:ReservationStatus.Pending}">
                    <Setter Property="Background" Value="{StaticResource WarningSoftBrush}" />
                    <Setter Property="TextElement.Foreground" Value="{StaticResource WarningBrush}" />
                </DataTrigger>
                <DataTrigger Binding="{Binding Status}" Value="{x:Static enums:ReservationStatus.Confirmed}">
                    <Setter Property="Background" Value="{StaticResource InfoSoftBrush}" />
                    <Setter Property="TextElement.Foreground" Value="{StaticResource InfoBrush}" />
                </DataTrigger>
                <DataTrigger Binding="{Binding Status}" Value="{x:Static enums:ReservationStatus.CheckedIn}">
                    <Setter Property="Background" Value="{StaticResource SuccessSoftBrush}" />
                    <Setter Property="TextElement.Foreground" Value="{StaticResource SuccessBrush}" />
                </DataTrigger>
                <DataTrigger Binding="{Binding Status}" Value="{x:Static enums:ReservationStatus.Completed}">
                    <Setter Property="Background" Value="{StaticResource BrandSoftBrush}" />
                    <Setter Property="TextElement.Foreground" Value="{StaticResource BrandDarkBrush}" />
                </DataTrigger>
                <DataTrigger Binding="{Binding Status}" Value="{x:Static enums:ReservationStatus.Cancelled}">
                    <Setter Property="Background" Value="{StaticResource DangerSoftBrush}" />
                    <Setter Property="TextElement.Foreground" Value="{StaticResource DangerBrush}" />
                </DataTrigger>
                <DataTrigger Binding="{Binding Status}" Value="{x:Static enums:ReservationStatus.NoShow}">
                    <Setter Property="Background" Value="{StaticResource DangerSoftBrush}" />
                    <Setter Property="TextElement.Foreground" Value="{StaticResource DangerBrush}" />
                </DataTrigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="ResRowItem" TargetType="ListBoxItem">
            <Setter Property="Margin" Value="0,0,0,8" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ListBoxItem">
                        <Border x:Name="bd" Background="{StaticResource CardBrush}"
                                BorderBrush="{StaticResource LineBrush}" BorderThickness="1"
                                CornerRadius="4" Padding="10,8" Cursor="Hand">
                            <ContentPresenter />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="bd" Property="Background" Value="#F5F6F2" />
                            </Trigger>
                            <Trigger Property="IsSelected" Value="True">
                                <Setter TargetName="bd" Property="Background" Value="{StaticResource BrandSoftBrush}" />
                                <Setter TargetName="bd" Property="BorderBrush" Value="{StaticResource BrandBrush}" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </UserControl.Resources>

    <Grid Margin="24,18,24,24">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <TextBlock Grid.Row="0" Text="Đặt phòng" Style="{StaticResource PageTitleText}" Margin="0,0,0,12" />

        <!-- Toolbar: lọc trạng thái + tìm + nút thêm -->
        <DockPanel Grid.Row="1" Margin="0,0,0,12">
            <Button DockPanel.Dock="Right" Content="+ Tạo đặt phòng"
                    Style="{StaticResource PrimaryButton}" Padding="16,8"
                    Command="{Binding AddCommand}" />
            <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                <ComboBox Width="150" ItemsSource="{Binding StatusFilters}"
                          SelectedItem="{Binding SelectedFilter}" DisplayMemberPath="Label" />
                <TextBox Width="220" Margin="10,0,0,0" VerticalAlignment="Center"
                         Text="{Binding SearchText, UpdateSourceTrigger=PropertyChanged}"
                         ToolTip="Tìm theo tên khách, số phòng, mã đặt" />
                <TextBlock Text="{Binding TotalText}" Style="{StaticResource CaptionText}"
                           FontSize="12.5" VerticalAlignment="Center" Margin="12,0,0,0" />
            </StackPanel>
        </DockPanel>

        <hc:LoadingCircle Grid.Row="2" Width="34" Height="34"
                          Foreground="{StaticResource BrandBrush}"
                          Visibility="{Binding IsLoading, Converter={StaticResource BoolToVis}}" />
        <TextBlock Grid.Row="2" Text="Chưa có đặt phòng nào — bấm + Tạo đặt phòng để bắt đầu."
                   Style="{StaticResource CaptionText}" FontSize="13"
                   HorizontalAlignment="Center" VerticalAlignment="Center"
                   Visibility="{Binding IsEmpty, Converter={StaticResource BoolToVis}}" />

        <Grid Grid.Row="2">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="1.4*" />
                <ColumnDefinition Width="16" />
                <ColumnDefinition Width="1*" />
            </Grid.ColumnDefinitions>

            <ListBox Grid.Column="0" ItemsSource="{Binding RowsView}"
                     SelectedItem="{Binding SelectedRow}"
                     ItemContainerStyle="{StaticResource ResRowItem}"
                     Background="Transparent" BorderThickness="0"
                     ScrollViewer.HorizontalScrollBarVisibility="Disabled">
                <ListBox.ItemTemplate>
                    <DataTemplate>
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            <Border Grid.Column="0" Width="58" Height="42" CornerRadius="4">
                                <Border.Background>
                                    <ImageBrush ImageSource="{Binding Thumbnail}" Stretch="UniformToFill" />
                                </Border.Background>
                            </Border>
                            <StackPanel Grid.Column="1" Margin="12,0,10,0" VerticalAlignment="Center">
                                <TextBlock Text="{Binding GuestName}" FontSize="14" FontWeight="SemiBold" />
                                <TextBlock Text="{Binding SubText}" Style="{StaticResource CaptionText}"
                                           FontSize="11.5" TextTrimming="CharacterEllipsis" Margin="0,2,0,0" />
                            </StackPanel>
                            <Border Grid.Column="2" Style="{StaticResource ResBadge}" VerticalAlignment="Center">
                                <TextBlock Text="{Binding StatusText}" />
                            </Border>
                        </Grid>
                    </DataTemplate>
                </ListBox.ItemTemplate>
            </ListBox>

            <!-- Panel chi tiết -->
            <Border Grid.Column="2" Style="{StaticResource Card}" Padding="0"
                    Effect="{StaticResource SoftShadow}" VerticalAlignment="Top">
                <Grid>
                    <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center" Margin="20,60"
                                TextElement.Foreground="{StaticResource InkSoftBrush}">
                        <StackPanel.Style>
                            <Style TargetType="StackPanel">
                                <Setter Property="Visibility" Value="Visible" />
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding HasSelection}" Value="True">
                                        <Setter Property="Visibility" Value="Collapsed" />
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </StackPanel.Style>
                        <TextBlock Text="&#xE8BC;" Style="{StaticResource IconText}" FontSize="28" HorizontalAlignment="Center" />
                        <TextBlock Text="Chọn một đặt phòng để xem chi tiết" Style="{StaticResource CaptionText}"
                                   FontSize="12.5" HorizontalAlignment="Center" Margin="0,10,0,0" />
                    </StackPanel>

                    <StackPanel DataContext="{Binding SelectedRow}">
                        <StackPanel.Style>
                            <Style TargetType="StackPanel">
                                <Setter Property="Visibility" Value="Collapsed" />
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding DataContext.HasSelection, RelativeSource={RelativeSource AncestorType=UserControl}}" Value="True">
                                        <Setter Property="Visibility" Value="Visible" />
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </StackPanel.Style>
                        <Border Height="140" CornerRadius="4,4,0,0">
                            <Border.Background>
                                <ImageBrush ImageSource="{Binding Thumbnail}" Stretch="UniformToFill" />
                            </Border.Background>
                        </Border>
                        <StackPanel Margin="18,16,18,18">
                            <DockPanel>
                                <Border DockPanel.Dock="Right" Style="{StaticResource ResBadge}" VerticalAlignment="Center">
                                    <TextBlock Text="{Binding StatusText}" />
                                </Border>
                                <TextBlock Text="{Binding GuestName}" Style="{StaticResource SectionTitleText}" FontSize="17" />
                            </DockPanel>
                            <TextBlock Text="{Binding BookingCode}" Style="{StaticResource CaptionText}"
                                       FontSize="12" Margin="0,3,0,14" />

                            <Border Height="1" Background="{StaticResource LineBrush}" Margin="0,0,0,12" />
                            <UniformGrid Columns="2">
                                <StackPanel Margin="0,0,0,10">
                                    <TextBlock Text="PHÒNG" Style="{StaticResource FieldLabel}" />
                                    <TextBlock Text="{Binding RoomNumber}" FontWeight="SemiBold" />
                                </StackPanel>
                                <StackPanel Margin="0,0,0,10">
                                    <TextBlock Text="LOẠI PHÒNG" Style="{StaticResource FieldLabel}" />
                                    <TextBlock Text="{Binding TypeName}" FontWeight="SemiBold" />
                                </StackPanel>
                                <StackPanel Margin="0,0,0,10">
                                    <TextBlock Text="NHẬN → TRẢ" Style="{StaticResource FieldLabel}" />
                                    <TextBlock Text="{Binding DateRange}" FontWeight="SemiBold" />
                                </StackPanel>
                                <StackPanel Margin="0,0,0,10">
                                    <TextBlock Text="SỐ KHÁCH" Style="{StaticResource FieldLabel}" />
                                    <TextBlock Text="{Binding GuestCountText}" FontWeight="SemiBold" />
                                </StackPanel>
                            </UniformGrid>

                            <TextBlock Text="YÊU CẦU ĐẶC BIỆT" Style="{StaticResource FieldLabel}" Margin="0,2,0,3"
                                       Visibility="{Binding HasSpecialRequests, Converter={StaticResource BoolToVis}}" />
                            <TextBlock Text="{Binding SpecialRequests}" Style="{StaticResource CaptionText}"
                                       FontSize="12" TextWrapping="Wrap"
                                       Visibility="{Binding HasSpecialRequests, Converter={StaticResource BoolToVis}}" />

                            <Border Height="1" Background="{StaticResource LineBrush}" Margin="0,16,0,14" />
                            <WrapPanel>
                                <Button Content="Xác nhận" Style="{StaticResource PrimaryButton}" Padding="14,7" Margin="0,0,8,8"
                                        Visibility="{Binding CanConfirm, Converter={StaticResource BoolToVis}}"
                                        Command="{Binding DataContext.ConfirmCommand, RelativeSource={RelativeSource AncestorType=UserControl}}" />
                                <Button Content="Sửa" Style="{StaticResource GhostButton}" Padding="14,7" Margin="0,0,8,8"
                                        Visibility="{Binding CanEdit, Converter={StaticResource BoolToVis}}"
                                        Command="{Binding DataContext.EditCommand, RelativeSource={RelativeSource AncestorType=UserControl}}" />
                                <Button Content="Không đến" Style="{StaticResource GhostButton}" Padding="14,7" Margin="0,0,8,8"
                                        Foreground="{StaticResource WarningBrush}"
                                        Visibility="{Binding CanNoShow, Converter={StaticResource BoolToVis}}"
                                        Command="{Binding DataContext.NoShowCommand, RelativeSource={RelativeSource AncestorType=UserControl}}" />
                                <Button Content="Huỷ" Style="{StaticResource GhostButton}" Padding="14,7" Margin="0,0,0,8"
                                        Foreground="{StaticResource DangerBrush}"
                                        Visibility="{Binding CanCancel, Converter={StaticResource BoolToVis}}"
                                        Command="{Binding DataContext.CancelCommand, RelativeSource={RelativeSource AncestorType=UserControl}}" />
                            </WrapPanel>
                        </StackPanel>
                    </StackPanel>
                </Grid>
            </Border>
        </Grid>
    </Grid>
</UserControl>
