<UserControl x:Class="FUHotelManagementWPF.Views.Reservations.ReservationsView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:hc="https://handyorg.github.io/handycontrol"
             xmlns:res="clr-namespace:FUHotelManagementWPF.Views.Reservations"
             xmlns:enums="clr-namespace:BusinessObjects.Enums;assembly=BusinessObjects">
    <UserControl.Resources>
        <!-- Badge trạng thái đặt phòng theo Reservation.Status -->
        <Style x:Key="ResBadge" TargetType="Border" BasedOn="{StaticResource BadgeBase}">
            <Setter Property="Background" Value="{StaticResource SurfaceAltBrush}" />
            <Setter Property="TextElement.Foreground" Value="{StaticResource InkSoftBrush}" />
            <Style.Triggers>
                <DataTrigger Binding="{Binding Status}" Value="{x:Static enums:ReservationStatus.Pending}">
                    <Setter Property="Background" Value="{StaticResource WarningSoftBrush}" />
                    <Setter Property="TextElement.Foreground" Value="{StaticResource WarningBrush}" />
                </DataTrigger>
                <DataTrigger Binding="{Binding Status}" Value="{x:Static enums:ReservationStatus.Confirmed}">
                    <Setter Property="Background" Value="{StaticResource InfoSoftBrush}" />
                    <Setter Property="TextElement.Foreground" Value="{StaticResource InfoBrush}" />
                </DataTrigger>
                <DataTrigger Binding="{Binding Status}" Value="{x:Static enums:ReservationStatus.CheckedIn}">
                    <Setter Property="Background" Value="{StaticResource SuccessSoftBrush}" />
                    <Setter Property="TextElement.Foreground" Value="{StaticResource SuccessBrush}" />
                </DataTrigger>
                <DataTrigger Binding="{Binding Status}" Value="{x:Static enums:ReservationStatus.Completed}">
                    <Setter Property="Background" Value="{StaticResource BrandSoftBrush}" />
                    <Setter Property="TextElement.Foreground" Value="{StaticResource BrandDarkBrush}" />
                </DataTrigger>
                <DataTrigger Binding="{Binding Status}" Value="{x:Static enums:ReservationStatus.Cancelled}">
                    <Setter Property="Background" Value="{StaticResource DangerSoftBrush}" />
                    <Setter Property="TextElement.Foreground" Value="{StaticResource DangerBrush}" />
                </DataTrigger>
                <DataTrigger Binding="{Binding Status}" Value="{x:Static enums:ReservationStatus.NoShow}">
                    <Setter Property="Background" Value="{StaticResource DangerSoftBrush}" />
                    <Setter Property="TextElement.Foreground" Value="{StaticResource DangerBrush}" />
                </DataTrigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="ResRowItem" TargetType="ListBoxItem">
            <Setter Property="Margin" Value="0,0,0,8" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ListBoxItem">
                        <Border x:Name="bd" Background="{StaticResource CardBrush}"
                                BorderBrush="{StaticResource LineBrush}" BorderThickness="1"
                                CornerRadius="4" Padding="10,8" Cursor="Hand">
                            <ContentPresenter />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="bd" Property="Background" Value="#F5F6F2" />
                            </Trigger>
                            <Trigger Property="IsSelected" Value="True">
                                <Setter TargetName="bd" Property="BorderBrush" Value="{StaticResource BrandBrush}" />
                                <Setter TargetName="bd" Property="BorderThickness" Value="1.5" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="ResChip" TargetType="Button">
            <Setter Property="Padding" Value="11,5" />
            <Setter Property="FontSize" Value="12" />
            <Setter Property="Margin" Value="0,0,7,0" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="Foreground" Value="{StaticResource InkBrush}" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="bd" Background="{StaticResource CardBrush}" CornerRadius="4"
                                BorderBrush="{StaticResource LineBrush}" BorderThickness="1"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter VerticalAlignment="Center" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="bd" Property="Background" Value="{StaticResource SurfaceAltBrush}" />
                            </Trigger>
                            <DataTrigger Binding="{Binding IsSelected}" Value="True">
                                <Setter TargetName="bd" Property="Background" Value="{StaticResource BrandBrush}" />
                                <Setter TargetName="bd" Property="BorderBrush" Value="{StaticResource BrandBrush}" />
                                <Setter Property="Foreground" Value="White" />
                            </DataTrigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </UserControl.Resources>

    <Grid Margin="24,18,24,24">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <TextBlock Grid.Row="0" Text="Đặt phòng" Style="{StaticResource PageTitleText}" Margin="0,0,0,10" />

        <TabControl Grid.Row="1" Background="Transparent" BorderThickness="0">
            <!-- ============ TAB 1: DANH SACH ============ -->
            <TabItem Header="Danh sách">
                <Grid Margin="0,14,0,0">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>

                    <!-- Tat ca cong cu gom mot hang: tim, loc, tong so, nut tao -->
                    <Grid Grid.Row="0" Margin="0,0,0,12">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" MaxWidth="320" />
                            <ColumnDefinition Width="10" />
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>

                        <TextBox Grid.Column="0" VerticalAlignment="Center"
                                 hc:InfoElement.Placeholder="Tìm khách, số phòng, mã đặt…"
                                 Text="{Binding SearchText, UpdateSourceTrigger=PropertyChanged}"
                                 ToolTip="Tìm theo tên khách, số phòng, mã đặt" />

                        <ComboBox Grid.Column="2" MinWidth="170" VerticalAlignment="Center"
                                  ItemsSource="{Binding Chips}" SelectedItem="{Binding SelectedChip}"
                                  DisplayMemberPath="Display"
                                  ToolTip="Lọc theo trạng thái đặt phòng" />

                        <TextBlock Grid.Column="3" Text="{Binding TotalText}"
                                   Style="{StaticResource CaptionText}" FontSize="12.5"
                                   VerticalAlignment="Center" Margin="12,0,0,0" />

                        <Button Grid.Column="5" Content="+ Tạo đặt phòng"
                                Style="{StaticResource PrimaryButton}" Padding="16,8"
                                Command="{Binding AddCommand}" />
                    </Grid>

                    <hc:LoadingCircle Grid.Row="2" Width="34" Height="34"
                                      Foreground="{StaticResource BrandBrush}"
                                      Visibility="{Binding IsLoading, Converter={StaticResource BoolToVis}}" />
                    <TextBlock Grid.Row="2" Text="Chưa có đặt phòng nào — bấm + Tạo đặt phòng để bắt đầu."
                               Style="{StaticResource CaptionText}" FontSize="13"
                               HorizontalAlignment="Center" VerticalAlignment="Center"
                               Visibility="{Binding IsEmpty, Converter={StaticResource BoolToVis}}" />

                    <!-- Thẻ có ảnh; hàng nút hành động chỉ bung ra ở thẻ đang chọn -->
                    <ListBox Grid.Row="2" ItemsSource="{Binding RowsView}"
                             SelectedItem="{Binding SelectedRow}"
                             ItemContainerStyle="{StaticResource ResRowItem}"
                             Background="Transparent" BorderThickness="0"
                             ScrollViewer.HorizontalScrollBarVisibility="Disabled">
                        <ListBox.ItemTemplate>
                            <DataTemplate>
                                <StackPanel>
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="Auto" />
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="Auto" />
                                            <ColumnDefinition Width="Auto" />
                                        </Grid.ColumnDefinitions>

                                        <Border Grid.Column="0" Width="58" Height="42" CornerRadius="4">
                                            <Border.Background>
                                                <ImageBrush ImageSource="{Binding Thumbnail}" Stretch="UniformToFill" />
                                            </Border.Background>
                                        </Border>

                                        <StackPanel Grid.Column="1" Margin="12,0,10,0" VerticalAlignment="Center">
                                            <StackPanel Orientation="Horizontal">
                                                <TextBlock Text="{Binding RoomNumber}" FontSize="14" FontWeight="SemiBold" />
                                                <TextBlock Text=" · " Foreground="{StaticResource InkSoftBrush}" />
                                                <TextBlock Text="{Binding GuestName}" FontSize="14" />
                                            </StackPanel>
                                            <TextBlock Style="{StaticResource CaptionText}" FontSize="11.5"
                                                       TextTrimming="CharacterEllipsis" Margin="0,2,0,0">
                                                <Run Text="{Binding TypeName, Mode=OneWay}" /><Run Text=" · " /><Run
                                                Text="{Binding GuestCountText, Mode=OneWay}" /><Run Text=" · " /><Run
                                                Text="{Binding DateRange, Mode=OneWay}" /><Run Text=" · " /><Run
                                                Text="{Binding BookingCode, Mode=OneWay}" />
                                            </TextBlock>
                                        </StackPanel>

                                        <Border Grid.Column="2" Style="{StaticResource ResBadge}"
                                                VerticalAlignment="Center" Margin="0,0,10,0">
                                            <TextBlock Text="{Binding StatusText}" />
                                        </Border>
                                    </Grid>

                                    <!-- Hành động: chỉ hiện ở thẻ đang chọn, và chỉ nút nào hợp lệ -->
                                    <StackPanel Orientation="Horizontal" Margin="0,9,0,1">
                                        <StackPanel.Style>
                                            <Style TargetType="StackPanel">
                                                <Setter Property="Visibility" Value="Collapsed" />
                                                <Style.Triggers>
                                                    <DataTrigger Value="True" Binding="{Binding IsSelected,
                                                        RelativeSource={RelativeSource AncestorType=ListBoxItem}}">
                                                        <Setter Property="Visibility" Value="Visible" />
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </StackPanel.Style>

                                        <Button Content="Xác nhận" Style="{StaticResource PrimaryButton}"
                                                Padding="14,6" Margin="0,0,7,0"
                                                Visibility="{Binding CanConfirm, Converter={StaticResource BoolToVis}}"
                                                Command="{Binding DataContext.ConfirmCommand,
                                                          RelativeSource={RelativeSource AncestorType=UserControl}}" />
                                        <Button Content="Sửa" Style="{StaticResource GhostButton}"
                                                Padding="14,6" Margin="0,0,7,0"
                                                Visibility="{Binding CanEdit, Converter={StaticResource BoolToVis}}"
                                                Command="{Binding DataContext.EditCommand,
                                                          RelativeSource={RelativeSource AncestorType=UserControl}}" />
                                        <Button Content="Huỷ" Style="{StaticResource GhostButton}"
                                                Padding="14,6" Margin="0,0,7,0"
                                                Foreground="{StaticResource DangerBrush}"
                                                Visibility="{Binding CanCancel, Converter={StaticResource BoolToVis}}"
                                                Command="{Binding DataContext.CancelCommand,
                                                          RelativeSource={RelativeSource AncestorType=UserControl}}" />
                                        <Button Content="Không đến" Style="{StaticResource GhostButton}"
                                                Padding="14,6"
                                                Visibility="{Binding CanNoShow, Converter={StaticResource BoolToVis}}"
                                                Command="{Binding DataContext.NoShowCommand,
                                                          RelativeSource={RelativeSource AncestorType=UserControl}}" />
                                        <TextBlock Text="{Binding SpecialRequests}" Style="{StaticResource CaptionText}"
                                                   FontSize="11.5" VerticalAlignment="Center" Margin="12,0,0,0"
                                                   TextTrimming="CharacterEllipsis" MaxWidth="320"
                                                   Visibility="{Binding HasSpecialRequests, Converter={StaticResource BoolToVis}}" />
                                    </StackPanel>
                                </StackPanel>
                            </DataTemplate>
                        </ListBox.ItemTemplate>
                    </ListBox>
                </Grid>
            </TabItem>

            <!-- ============ TAB 2: LICH PHONG ============ -->
            <TabItem Header="Lịch phòng">
                <res:RoomCalendarView DataContext="{Binding Calendar}" />
            </TabItem>
        </TabControl>
    </Grid>
</UserControl>
