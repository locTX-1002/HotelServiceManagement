<UserControl x:Class="FUHotelManagementWPF.Views.Rooms.RoomMapView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:hc="https://handyorg.github.io/handycontrol"
             xmlns:enums="clr-namespace:BusinessObjects.Enums;assembly=BusinessObjects">
    <UserControl.Resources>
        <!-- Cham mau trang thai (semantic, khong phai trang tri) -->
        <Style x:Key="StatusDot" TargetType="Ellipse">
            <Setter Property="Width" Value="7" />
            <Setter Property="Height" Value="7" />
            <Setter Property="VerticalAlignment" Value="Center" />
            <Setter Property="Fill" Value="{StaticResource InkSoftBrush}" />
            <Style.Triggers>
                <DataTrigger Binding="{Binding Room.Status}" Value="{x:Static enums:RoomStatus.Available}">
                    <Setter Property="Fill" Value="{StaticResource SuccessBrush}" />
                </DataTrigger>
                <DataTrigger Binding="{Binding Room.Status}" Value="{x:Static enums:RoomStatus.Occupied}">
                    <Setter Property="Fill" Value="{StaticResource WarningBrush}" />
                </DataTrigger>
                <DataTrigger Binding="{Binding Room.Status}" Value="{x:Static enums:RoomStatus.Reserved}">
                    <Setter Property="Fill" Value="{StaticResource InfoBrush}" />
                </DataTrigger>
                <DataTrigger Binding="{Binding Room.Status}" Value="{x:Static enums:RoomStatus.Maintenance}">
                    <Setter Property="Fill" Value="{StaticResource DangerBrush}" />
                </DataTrigger>
            </Style.Triggers>
        </Style>

        <!-- Cham trang thai dat tren anh toi: dung ban mau sang hon de con nhin thay -->
        <Style x:Key="StatusDotOnImage" TargetType="Ellipse" BasedOn="{StaticResource StatusDot}">
            <Setter Property="Fill" Value="#C9CFC4" />
            <Style.Triggers>
                <DataTrigger Binding="{Binding Room.Status}" Value="{x:Static enums:RoomStatus.Available}">
                    <Setter Property="Fill" Value="#7ED08A" />
                </DataTrigger>
                <DataTrigger Binding="{Binding Room.Status}" Value="{x:Static enums:RoomStatus.Occupied}">
                    <Setter Property="Fill" Value="#F0B15A" />
                </DataTrigger>
                <DataTrigger Binding="{Binding Room.Status}" Value="{x:Static enums:RoomStatus.Reserved}">
                    <Setter Property="Fill" Value="#7FBEDD" />
                </DataTrigger>
                <DataTrigger Binding="{Binding Room.Status}" Value="{x:Static enums:RoomStatus.Maintenance}">
                    <Setter Property="Fill" Value="#EE8A82" />
                </DataTrigger>
            </Style.Triggers>
        </Style>

        <!-- So dem tren thanh thong ke: to mau theo trang thai (path Status, khong phai Room.Status) -->
        <Style x:Key="StatusCountNumber" TargetType="TextBlock">
            <Setter Property="FontSize" Value="17" />
            <Setter Property="FontWeight" Value="Bold" />
            <Setter Property="Foreground" Value="{StaticResource InkBrush}" />
            <Setter Property="VerticalAlignment" Value="Center" />
            <Style.Triggers>
                <DataTrigger Binding="{Binding Status}" Value="{x:Static enums:RoomStatus.Occupied}">
                    <Setter Property="Foreground" Value="{StaticResource WarningBrush}" />
                </DataTrigger>
                <DataTrigger Binding="{Binding Status}" Value="{x:Static enums:RoomStatus.Reserved}">
                    <Setter Property="Foreground" Value="{StaticResource InfoBrush}" />
                </DataTrigger>
                <DataTrigger Binding="{Binding Status}" Value="{x:Static enums:RoomStatus.Cleaning}">
                    <Setter Property="Foreground" Value="{StaticResource SuccessBrush}" />
                </DataTrigger>
                <DataTrigger Binding="{Binding Status}" Value="{x:Static enums:RoomStatus.Maintenance}">
                    <Setter Property="Foreground" Value="{StaticResource DangerBrush}" />
                </DataTrigger>
            </Style.Triggers>
        </Style>
    </UserControl.Resources>

    <Grid Margin="0,14,0,0">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <!-- Thanh thong ke tong quan -->
        <Border Grid.Row="0" Style="{StaticResource Card}" Padding="6,10" Margin="0,0,0,14">
            <ItemsControl ItemsSource="{Binding StatusCounts}">
                <ItemsControl.ItemsPanel>
                    <ItemsPanelTemplate>
                        <StackPanel Orientation="Horizontal" />
                    </ItemsPanelTemplate>
                </ItemsControl.ItemsPanel>
                <ItemsControl.ItemTemplate>
                    <DataTemplate>
                        <StackPanel Orientation="Horizontal" Margin="18,0">
                            <TextBlock Text="{Binding Count}" Style="{StaticResource StatusCountNumber}" />
                            <TextBlock Text="{Binding Label}" Style="{StaticResource CaptionText}"
                                       FontSize="12.5" VerticalAlignment="Center" Margin="7,1,0,0" />
                        </StackPanel>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>
        </Border>

        <!-- Dang tai / trong -->
        <hc:LoadingCircle Grid.Row="1" Width="34" Height="34"
                          Foreground="{StaticResource BrandBrush}"
                          Visibility="{Binding IsLoading, Converter={StaticResource BoolToVis}}" />
        <TextBlock Grid.Row="1"
                   Text="Chưa có phòng nào đang hoạt động — thêm phòng ở tab Danh sách phòng."
                   Style="{StaticResource CaptionText}" FontSize="13"
                   HorizontalAlignment="Center" VerticalAlignment="Center"
                   Visibility="{Binding IsEmpty, Converter={StaticResource BoolToVis}}" />

        <!-- Luoi phong: nhom theo tang (GroupDescriptions), moi nhom la UniformGrid 6 cot -->
        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
            <ItemsControl ItemsSource="{Binding RoomsView}">
                <ItemsControl.GroupStyle>
                    <GroupStyle>
                        <GroupStyle.HeaderTemplate>
                            <DataTemplate>
                                <TextBlock Text="{Binding Name}" FontSize="11" FontWeight="Bold"
                                           Foreground="{StaticResource InkSoftBrush}"
                                           Margin="2,10,0,7" />
                            </DataTemplate>
                        </GroupStyle.HeaderTemplate>
                    </GroupStyle>
                </ItemsControl.GroupStyle>
                <ItemsControl.ItemsPanel>
                    <ItemsPanelTemplate>
                        <UniformGrid Columns="6" />
                    </ItemsPanelTemplate>
                </ItemsControl.ItemsPanel>
                <ItemsControl.ItemTemplate>
                    <DataTemplate>
                        <!-- The anh giong luoi hang phong o trang chu: anh phu kin o,
                             so phong va trang thai de len day anh -->
                        <Border x:Name="tile" Height="112" CornerRadius="4" Margin="0,0,10,10"
                                Cursor="Hand" ToolTip="Bấm để đổi trạng thái vận hành">
                            <Border.InputBindings>
                                <MouseBinding Gesture="LeftClick"
                                              Command="{Binding DataContext.ChangeStatusCommand,
                                                        RelativeSource={RelativeSource AncestorType=UserControl}}"
                                              CommandParameter="{Binding}" />
                            </Border.InputBindings>
                            <Grid>
                                <Border CornerRadius="4">
                                    <Border.Background>
                                        <ImageBrush ImageSource="{Binding ThumbnailSource}"
                                                    Stretch="UniformToFill" />
                                    </Border.Background>
                                </Border>
                                <Border Style="{StaticResource TileShade}" />
                                <StackPanel VerticalAlignment="Bottom" Margin="11,0,11,9">
                                    <TextBlock Text="{Binding Room.RoomNumber}"
                                               Style="{StaticResource TileName}" FontSize="17" />
                                    <StackPanel Orientation="Horizontal" Margin="0,3,0,0">
                                        <Ellipse Style="{StaticResource StatusDotOnImage}" />
                                        <TextBlock Text="{Binding StatusText}"
                                                   Style="{StaticResource TileMeta}"
                                                   FontSize="11" Margin="6,0,0,0" />
                                    </StackPanel>
                                </StackPanel>
                            </Grid>
                        </Border>
                        <DataTemplate.Triggers>
                            <!-- Re chuot: vien sang len de biet dang tro vao o nao -->
                            <Trigger SourceName="tile" Property="IsMouseOver" Value="True">
                                <Setter TargetName="tile" Property="BorderBrush" Value="{StaticResource BrandBrush}" />
                                <Setter TargetName="tile" Property="BorderThickness" Value="2" />
                            </Trigger>
                        </DataTemplate.Triggers>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>
        </ScrollViewer>
    </Grid>
</UserControl>
