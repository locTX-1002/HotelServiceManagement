<UserControl x:Class="FUHotelManagementWPF.Views.Rooms.RoomListView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:hc="https://handyorg.github.io/handycontrol">
    <UserControl.Resources>
        <!-- Card-row trong ListBox: bo default highlight, chon thi vien + nen nhat brand -->
        <Style x:Key="RoomRowItem" TargetType="ListBoxItem">
            <Setter Property="Margin" Value="0,0,0,8" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ListBoxItem">
                        <Border x:Name="bd" Background="{StaticResource CardBrush}"
                                BorderBrush="{StaticResource LineBrush}" BorderThickness="1"
                                CornerRadius="4" Padding="10,8" Cursor="Hand">
                            <ContentPresenter />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="bd" Property="Background" Value="#F5F6F2" />
                            </Trigger>
                            <Trigger Property="IsSelected" Value="True">
                                <Setter TargetName="bd" Property="Background" Value="{StaticResource BrandSoftBrush}" />
                                <Setter TargetName="bd" Property="BorderBrush" Value="{StaticResource BrandBrush}" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        <!-- Chip loc trang thai: chip dang chon to mau thuong hieu -->
        <Style x:Key="StatusChip" TargetType="Button">
            <Setter Property="Padding" Value="11,5" />
            <Setter Property="FontSize" Value="12" />
            <Setter Property="Margin" Value="0,0,7,0" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="Foreground" Value="{StaticResource InkBrush}" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="bd" Background="{StaticResource CardBrush}" CornerRadius="4"
                                BorderBrush="{StaticResource LineBrush}" BorderThickness="1"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter VerticalAlignment="Center" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="bd" Property="Background" Value="{StaticResource SurfaceAltBrush}" />
                            </Trigger>
                            <DataTrigger Binding="{Binding IsSelected}" Value="True">
                                <Setter TargetName="bd" Property="Background" Value="{StaticResource BrandBrush}" />
                                <Setter TargetName="bd" Property="BorderBrush" Value="{StaticResource BrandBrush}" />
                                <Setter Property="Foreground" Value="White" />
                            </DataTrigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </UserControl.Resources>

    <Grid Margin="0,14,0,0">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <!-- Toolbar -->
        <DockPanel Grid.Row="0" Margin="0,0,0,12">
            <Button DockPanel.Dock="Right" Content="+ Thêm phòng"
                    Style="{StaticResource PrimaryButton}" Padding="16,8"
                    Command="{Binding AddCommand}" />
            <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                <TextBlock Text="Tìm:" Style="{StaticResource CaptionText}" FontSize="12.5"
                           VerticalAlignment="Center" Margin="2,0,8,0" />
                <TextBox Width="240" VerticalAlignment="Center"
                         Text="{Binding SearchText, UpdateSourceTrigger=PropertyChanged}"
                         ToolTip="Tìm theo số phòng hoặc tên loại phòng" />
                <TextBlock Text="{Binding TotalText}" Style="{StaticResource CaptionText}"
                           FontSize="12.5" VerticalAlignment="Center" Margin="14,0,0,0" />
            </StackPanel>
        </DockPanel>

        <!-- Chip loc trang thai (co so dem) -->
        <ItemsControl Grid.Row="1" ItemsSource="{Binding StatusChips}" Margin="0,0,0,12">
            <ItemsControl.ItemsPanel>
                <ItemsPanelTemplate>
                    <WrapPanel />
                </ItemsPanelTemplate>
            </ItemsControl.ItemsPanel>
            <ItemsControl.ItemTemplate>
                <DataTemplate>
                    <Button Style="{StaticResource StatusChip}"
                            Command="{Binding DataContext.PickStatusCommand,
                                      RelativeSource={RelativeSource AncestorType=UserControl}}"
                            CommandParameter="{Binding}">
                        <TextBlock><Run Text="{Binding Label, Mode=OneWay}" /><Run Text=" " /><Run
                            Text="{Binding Count, Mode=OneWay}" FontWeight="SemiBold" /></TextBlock>
                    </Button>
                </DataTemplate>
            </ItemsControl.ItemTemplate>
        </ItemsControl>

        <hc:LoadingCircle Grid.Row="2" Width="34" Height="34"
                          Foreground="{StaticResource BrandBrush}"
                          Visibility="{Binding IsLoading, Converter={StaticResource BoolToVis}}" />
        <TextBlock Grid.Row="2" Text="{Binding EmptyText}"
                   Style="{StaticResource CaptionText}" FontSize="13"
                   HorizontalAlignment="Center" VerticalAlignment="Center"
                   Visibility="{Binding IsEmpty, Converter={StaticResource BoolToVis}}" />

        <!-- D3 master-detail: danh sach trai + panel chi tiet phai -->
        <Grid Grid.Row="2">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="1.35*" />
                <ColumnDefinition Width="16" />
                <ColumnDefinition Width="1*" />
            </Grid.ColumnDefinitions>

            <!-- MASTER: card-row list -->
            <ListBox Grid.Column="0" ItemsSource="{Binding RowsView}"
                     SelectedItem="{Binding SelectedRow}"
                     ItemContainerStyle="{StaticResource RoomRowItem}"
                     Background="Transparent" BorderThickness="0"
                     ScrollViewer.HorizontalScrollBarVisibility="Disabled">
                <ListBox.ItemTemplate>
                    <DataTemplate>
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            <Border Grid.Column="0" Width="58" Height="42" CornerRadius="4">
                                <Border.Background>
                                    <ImageBrush ImageSource="{Binding ThumbnailSource}" Stretch="UniformToFill" />
                                </Border.Background>
                            </Border>
                            <StackPanel Grid.Column="1" Margin="12,0,10,0" VerticalAlignment="Center">
                                <TextBlock Text="{Binding Room.RoomNumber}" FontSize="14" FontWeight="SemiBold" />
                                <TextBlock Text="{Binding SubText}" Style="{StaticResource CaptionText}"
                                           FontSize="11.5" TextTrimming="CharacterEllipsis" Margin="0,2,0,0" />
                            </StackPanel>
                            <Border Grid.Column="2" Style="{StaticResource RoomStatusBadge}"
                                    VerticalAlignment="Center" Margin="0,0,12,0">
                                <TextBlock Text="{Binding StatusText}" />
                            </Border>
                            <TextBlock Grid.Column="3" Text="{Binding PriceText}"
                                       FontWeight="SemiBold" FontSize="12.5" VerticalAlignment="Center" />
                        </Grid>
                    </DataTemplate>
                </ListBox.ItemTemplate>
            </ListBox>

            <!-- DETAIL: panel chi tiet phong dang chon -->
            <Border Grid.Column="2" Style="{StaticResource Card}" Padding="0"
                    Effect="{StaticResource SoftShadow}" VerticalAlignment="Top">
                <Grid>
                    <!-- Chua chon -->
                    <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center"
                                Margin="20,60" TextElement.Foreground="{StaticResource InkSoftBrush}">
                        <StackPanel.Style>
                            <Style TargetType="StackPanel">
                                <Setter Property="Visibility" Value="Visible" />
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding DataContext.HasSelection, RelativeSource={RelativeSource AncestorType=UserControl}}" Value="True">
                                        <Setter Property="Visibility" Value="Collapsed" />
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </StackPanel.Style>
                        <TextBlock Text="&#xE80F;" Style="{StaticResource IconText}" FontSize="28"
                                   HorizontalAlignment="Center" />
                        <TextBlock Text="Chọn một phòng để xem chi tiết" Style="{StaticResource CaptionText}"
                                   FontSize="12.5" HorizontalAlignment="Center" Margin="0,10,0,0" />
                    </StackPanel>

                    <!-- Da chon -->
                    <StackPanel DataContext="{Binding SelectedRow}">
                        <StackPanel.Style>
                            <Style TargetType="StackPanel">
                                <Setter Property="Visibility" Value="Collapsed" />
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding DataContext.HasSelection, RelativeSource={RelativeSource AncestorType=UserControl}}" Value="True">
                                        <Setter Property="Visibility" Value="Visible" />
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </StackPanel.Style>
                        <!-- Gallery ảnh: mũi tên chuyển + bộ đếm (thay dialog Chi tiết cũ) -->
                        <Border Height="180" CornerRadius="4,4,0,0">
                            <Border.Background>
                                <ImageBrush ImageSource="{Binding DataContext.DetailImage,
                                            RelativeSource={RelativeSource AncestorType=UserControl}}"
                                            Stretch="UniformToFill" />
                            </Border.Background>
                            <Grid>
                                <Button Style="{StaticResource GalleryArrow}" Content="&#xE76B;"
                                        HorizontalAlignment="Left" Margin="10,0,0,0"
                                        Command="{Binding DataContext.PrevImageCommand,
                                                  RelativeSource={RelativeSource AncestorType=UserControl}}" />
                                <Button Style="{StaticResource GalleryArrow}" Content="&#xE76C;"
                                        HorizontalAlignment="Right" Margin="0,0,10,0"
                                        Command="{Binding DataContext.NextImageCommand,
                                                  RelativeSource={RelativeSource AncestorType=UserControl}}" />
                                <Border CornerRadius="4" Background="#99000000" Padding="9,3"
                                        HorizontalAlignment="Right" VerticalAlignment="Bottom" Margin="0,0,10,9">
                                    <TextBlock Text="{Binding DataContext.GalleryCounter,
                                               RelativeSource={RelativeSource AncestorType=UserControl}}"
                                               Foreground="White" FontSize="11" />
                                </Border>
                            </Grid>
                        </Border>
                        <StackPanel Margin="18,16,18,18">
                            <DockPanel>
                                <Border DockPanel.Dock="Right" Style="{StaticResource RoomStatusBadge}"
                                        VerticalAlignment="Center">
                                    <TextBlock Text="{Binding StatusText}" />
                                </Border>
                                <TextBlock Text="{Binding Room.RoomNumber, StringFormat=Phòng {0}}"
                                           Style="{StaticResource SectionTitleText}" FontSize="18" />
                            </DockPanel>
                            <TextBlock Text="{Binding TypeName}" Style="{StaticResource CaptionText}"
                                       FontSize="12.5" Margin="0,3,0,14" />

                            <Border Height="1" Background="{StaticResource LineBrush}" Margin="0,0,0,12" />
                            <UniformGrid Columns="2" >
                                <StackPanel Margin="0,0,0,10">
                                    <TextBlock Text="TẦNG" Style="{StaticResource FieldLabel}" />
                                    <TextBlock Text="{Binding FloorText}" FontWeight="SemiBold" />
                                </StackPanel>
                                <StackPanel Margin="0,0,0,10">
                                    <TextBlock Text="SỨC CHỨA" Style="{StaticResource FieldLabel}" />
                                    <TextBlock Text="{Binding CapacityText}" FontWeight="SemiBold" />
                                </StackPanel>
                                <StackPanel>
                                    <TextBlock Text="GIÁ / ĐÊM" Style="{StaticResource FieldLabel}" />
                                    <TextBlock Text="{Binding PriceText}" FontWeight="SemiBold" />
                                </StackPanel>
                                <StackPanel>
                                    <TextBlock Text="TÌNH TRẠNG" Style="{StaticResource FieldLabel}" />
                                    <TextBlock Text="{Binding ActiveText}" FontWeight="SemiBold" />
                                </StackPanel>
                            </UniformGrid>

                            <TextBlock Text="{Binding DescriptionText}" Style="{StaticResource CaptionText}"
                                       FontSize="12" TextWrapping="Wrap" Margin="0,12,0,0"
                                       Visibility="{Binding HasDescription, Converter={StaticResource BoolToVis}}" />

                            <Border Height="1" Background="{StaticResource LineBrush}" Margin="0,16,0,14" />
                            <WrapPanel>
                                <Button Content="Đổi trạng thái" Style="{StaticResource PrimaryButton}"
                                        Padding="14,7" Margin="0,0,8,8"
                                        Command="{Binding DataContext.ChangeStatusCommand,
                                                  RelativeSource={RelativeSource AncestorType=UserControl}}" />
                                <Button Content="Sửa" Style="{StaticResource GhostButton}"
                                        Padding="14,7" Margin="0,0,8,8"
                                        Command="{Binding DataContext.EditCommand,
                                                  RelativeSource={RelativeSource AncestorType=UserControl}}"
                                        CommandParameter="{Binding}" />
                                <Button Content="Xoá" Style="{StaticResource GhostButton}"
                                        Padding="14,7" Margin="0,0,0,8"
                                        Foreground="{StaticResource DangerBrush}"
                                        Command="{Binding DataContext.DeleteCommand,
                                                  RelativeSource={RelativeSource AncestorType=UserControl}}"
                                        CommandParameter="{Binding}" />
                            </WrapPanel>
                        </StackPanel>
                    </StackPanel>
                </Grid>
            </Border>
        </Grid>
    </Grid>
</UserControl>
