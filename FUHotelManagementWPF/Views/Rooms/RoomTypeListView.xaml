<UserControl x:Class="FUHotelManagementWPF.Views.Rooms.RoomTypeListView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:hc="https://handyorg.github.io/handycontrol">

    <Grid Margin="0,14,0,0">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <!-- Toolbar -->
        <DockPanel Grid.Row="0" Margin="0,0,0,12">
            <Button DockPanel.Dock="Right" Content="+ Thêm loại phòng"
                    Style="{StaticResource PrimaryButton}" Padding="16,8"
                    Command="{Binding AddCommand}" />
            <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                <TextBlock Text="Tìm:" Style="{StaticResource CaptionText}" FontSize="12.5"
                           VerticalAlignment="Center" Margin="2,0,8,0" />
                <TextBox Width="240" VerticalAlignment="Center"
                         Text="{Binding SearchText, UpdateSourceTrigger=PropertyChanged}"
                         ToolTip="Tìm theo tên hạng phòng hoặc mô tả" />
                <TextBlock Text="{Binding TotalText}" Style="{StaticResource CaptionText}"
                           FontSize="12.5" VerticalAlignment="Center" Margin="14,0,0,0" />
            </StackPanel>
        </DockPanel>

        <hc:LoadingCircle Grid.Row="1" Width="34" Height="34"
                          Foreground="{StaticResource BrandBrush}"
                          Visibility="{Binding IsLoading, Converter={StaticResource BoolToVis}}" />
        <TextBlock Grid.Row="1" Text="{Binding EmptyText}"
                   Style="{StaticResource CaptionText}" FontSize="13"
                   HorizontalAlignment="Center" VerticalAlignment="Center"
                   Visibility="{Binding IsEmpty, Converter={StaticResource BoolToVis}}" />

        <!-- Luoi the hang phong 2 cot: anh lon, gia noi bat, nut Sua/Xoa ngay tren the -->
        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto" Padding="0,0,4,0">
            <ItemsControl ItemsSource="{Binding RowsView}">
                <ItemsControl.ItemsPanel>
                    <ItemsPanelTemplate>
                        <UniformGrid Columns="2" />
                    </ItemsPanelTemplate>
                </ItemsControl.ItemsPanel>
                <ItemsControl.ItemTemplate>
                    <DataTemplate>
                        <Border Background="{StaticResource CardBrush}" CornerRadius="4"
                                BorderBrush="{StaticResource LineBrush}" BorderThickness="1"
                                Effect="{StaticResource SoftShadow}" Margin="0,0,12,12">
                            <Grid>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="*" />
                                </Grid.RowDefinitions>

                                <!-- Anh lon + huy hieu so phong + gia de len anh -->
                                <Border Grid.Row="0" Height="150" CornerRadius="4,4,0,0">
                                    <Border.Background>
                                        <ImageBrush ImageSource="{Binding Thumbnail}" Stretch="UniformToFill" />
                                    </Border.Background>
                                    <Grid>
                                        <Border CornerRadius="4" Background="#B3000000" Padding="9,4"
                                                HorizontalAlignment="Left" VerticalAlignment="Top" Margin="10">
                                            <TextBlock Text="{Binding RoomCountText}" Foreground="White" FontSize="11" />
                                        </Border>
                                        <Border CornerRadius="4" Background="{StaticResource BrandBrush}" Padding="11,5"
                                                HorizontalAlignment="Right" VerticalAlignment="Bottom" Margin="10">
                                            <TextBlock Text="{Binding PriceText}" Foreground="White"
                                                       FontSize="13.5" FontWeight="SemiBold" />
                                        </Border>
                                    </Grid>
                                </Border>

                                <StackPanel Grid.Row="1" Margin="15,13,15,13">
                                    <DockPanel>
                                        <Border DockPanel.Dock="Right" VerticalAlignment="Center">
                                            <Border.Style>
                                                <Style TargetType="Border" BasedOn="{StaticResource BadgeBase}">
                                                    <Setter Property="Background" Value="{StaticResource SuccessSoftBrush}" />
                                                    <Setter Property="TextElement.Foreground" Value="{StaticResource SuccessBrush}" />
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding IsActive}" Value="False">
                                                            <Setter Property="Background" Value="{StaticResource SurfaceAltBrush}" />
                                                            <Setter Property="TextElement.Foreground" Value="{StaticResource InkSoftBrush}" />
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </Border.Style>
                                            <TextBlock Text="{Binding ActiveText}" />
                                        </Border>
                                        <TextBlock Text="{Binding RoomType.TypeName}"
                                                   Style="{StaticResource SectionTitleText}" FontSize="16.5"
                                                   TextTrimming="CharacterEllipsis" VerticalAlignment="Center" />
                                    </DockPanel>

                                    <TextBlock Text="{Binding CapacityText}" Style="{StaticResource CaptionText}"
                                               FontSize="12" Margin="0,4,0,0" />
                                    <TextBlock Text="{Binding DescriptionText}" Style="{StaticResource CaptionText}"
                                               FontSize="12" TextWrapping="Wrap" MaxHeight="34" Margin="0,7,0,0"
                                               TextTrimming="CharacterEllipsis"
                                               Visibility="{Binding HasDescription, Converter={StaticResource BoolToVis}}" />

                                    <Border Height="1" Background="{StaticResource LineBrush}" Margin="0,12,0,10" />
                                    <StackPanel Orientation="Horizontal">
                                        <Button Content="Sửa" Style="{StaticResource GhostButton}"
                                                Padding="16,6" Margin="0,0,8,0"
                                                Command="{Binding DataContext.EditCommand,
                                                          RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                CommandParameter="{Binding}" />
                                        <Button Content="Xoá" Style="{StaticResource GhostButton}"
                                                Padding="16,6" Foreground="{StaticResource DangerBrush}"
                                                Command="{Binding DataContext.DeleteCommand,
                                                          RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                CommandParameter="{Binding}" />
                                    </StackPanel>
                                </StackPanel>
                            </Grid>
                        </Border>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>
        </ScrollViewer>
    </Grid>
</UserControl>
