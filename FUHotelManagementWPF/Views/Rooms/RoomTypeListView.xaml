<UserControl x:Class="FUHotelManagementWPF.Views.Rooms.RoomTypeListView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:hc="https://handyorg.github.io/handycontrol">
    <UserControl.Resources>
        <Style x:Key="TypeRowItem" TargetType="ListBoxItem">
            <Setter Property="Margin" Value="0,0,0,8" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ListBoxItem">
                        <Border x:Name="bd" Background="{StaticResource CardBrush}"
                                BorderBrush="{StaticResource LineBrush}" BorderThickness="1"
                                CornerRadius="4" Padding="10,8" Cursor="Hand">
                            <ContentPresenter />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="bd" Property="Background" Value="#F5F6F2" />
                            </Trigger>
                            <Trigger Property="IsSelected" Value="True">
                                <Setter TargetName="bd" Property="Background" Value="{StaticResource BrandSoftBrush}" />
                                <Setter TargetName="bd" Property="BorderBrush" Value="{StaticResource BrandBrush}" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </UserControl.Resources>

    <Grid Margin="0,14,0,0">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <DockPanel Grid.Row="0" Margin="0,0,0,12">
            <Button DockPanel.Dock="Right" Content="+ Thêm loại phòng"
                    Style="{StaticResource PrimaryButton}" Padding="16,8"
                    Command="{Binding AddCommand}" />
            <TextBlock VerticalAlignment="Center" Margin="2,0,0,0"
                       Style="{StaticResource CaptionText}" FontSize="12.5">
                <Run Text="{Binding TotalText, Mode=OneWay}" FontWeight="SemiBold"
                     Foreground="{StaticResource InkBrush}" />
                <Run Text=" · Xoá loại đang được phòng sử dụng sẽ chuyển sang ngừng dùng (giữ lịch sử)." />
            </TextBlock>
        </DockPanel>

        <hc:LoadingCircle Grid.Row="1" Width="34" Height="34"
                          Foreground="{StaticResource BrandBrush}"
                          Visibility="{Binding IsLoading, Converter={StaticResource BoolToVis}}" />
        <TextBlock Grid.Row="1" Text="Chưa có loại phòng nào — bấm + Thêm loại phòng để bắt đầu."
                   Style="{StaticResource CaptionText}" FontSize="13"
                   HorizontalAlignment="Center" VerticalAlignment="Center"
                   Visibility="{Binding IsEmpty, Converter={StaticResource BoolToVis}}" />

        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="1.35*" />
                <ColumnDefinition Width="16" />
                <ColumnDefinition Width="1*" />
            </Grid.ColumnDefinitions>

            <ListBox Grid.Column="0" ItemsSource="{Binding Rows}"
                     SelectedItem="{Binding SelectedRow}"
                     ItemContainerStyle="{StaticResource TypeRowItem}"
                     Background="Transparent" BorderThickness="0"
                     ScrollViewer.HorizontalScrollBarVisibility="Disabled">
                <ListBox.ItemTemplate>
                    <DataTemplate>
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            <Border Grid.Column="0" Width="58" Height="42" CornerRadius="4">
                                <Border.Background>
                                    <ImageBrush ImageSource="{Binding Thumbnail}" Stretch="UniformToFill" />
                                </Border.Background>
                            </Border>
                            <StackPanel Grid.Column="1" Margin="12,0,10,0" VerticalAlignment="Center">
                                <TextBlock Text="{Binding RoomType.TypeName}" FontSize="14" FontWeight="SemiBold" />
                                <TextBlock Text="{Binding SubText}" Style="{StaticResource CaptionText}"
                                           FontSize="11.5" TextTrimming="CharacterEllipsis" Margin="0,2,0,0" />
                            </StackPanel>
                            <Border Grid.Column="2" Style="{StaticResource BadgeInfo}"
                                    VerticalAlignment="Center" Margin="0,0,12,0">
                                <TextBlock Text="{Binding RoomCountText}" />
                            </Border>
                            <TextBlock Grid.Column="3" Text="{Binding PriceText}"
                                       FontWeight="SemiBold" FontSize="12.5" VerticalAlignment="Center" />
                        </Grid>
                    </DataTemplate>
                </ListBox.ItemTemplate>
            </ListBox>

            <Border Grid.Column="2" Style="{StaticResource Card}" Padding="0"
                    Effect="{StaticResource SoftShadow}" VerticalAlignment="Top">
                <Grid>
                    <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center"
                                Margin="20,60" TextElement.Foreground="{StaticResource InkSoftBrush}">
                        <StackPanel.Style>
                            <Style TargetType="StackPanel">
                                <Setter Property="Visibility" Value="Visible" />
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding HasSelection}" Value="True">
                                        <Setter Property="Visibility" Value="Collapsed" />
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </StackPanel.Style>
                        <TextBlock Text="&#xE80F;" Style="{StaticResource IconText}" FontSize="28"
                                   HorizontalAlignment="Center" />
                        <TextBlock Text="Chọn một loại phòng để xem chi tiết"
                                   Style="{StaticResource CaptionText}" FontSize="12.5"
                                   HorizontalAlignment="Center" Margin="0,10,0,0" />
                    </StackPanel>

                    <StackPanel DataContext="{Binding SelectedRow}">
                        <StackPanel.Style>
                            <Style TargetType="StackPanel">
                                <Setter Property="Visibility" Value="Collapsed" />
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding}" Value="{x:Null}">
                                        <Setter Property="Visibility" Value="Collapsed" />
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </StackPanel.Style>
                        <Border Height="150" CornerRadius="4,4,0,0">
                            <Border.Background>
                                <ImageBrush ImageSource="{Binding Thumbnail}" Stretch="UniformToFill" />
                            </Border.Background>
                        </Border>
                        <StackPanel Margin="18,16,18,18">
                            <DockPanel>
                                <Border DockPanel.Dock="Right" Style="{StaticResource BadgeInfo}"
                                        VerticalAlignment="Center">
                                    <TextBlock Text="{Binding RoomCountText}" />
                                </Border>
                                <TextBlock Text="{Binding RoomType.TypeName}"
                                           Style="{StaticResource SectionTitleText}" FontSize="18" />
                            </DockPanel>
                            <TextBlock Text="{Binding ActiveText}" Style="{StaticResource CaptionText}"
                                       FontSize="12.5" Margin="0,3,0,14" />

                            <Border Height="1" Background="{StaticResource LineBrush}" Margin="0,0,0,12" />
                            <UniformGrid Columns="2">
                                <StackPanel Margin="0,0,0,10">
                                    <TextBlock Text="SỨC CHỨA" Style="{StaticResource FieldLabel}" />
                                    <TextBlock Text="{Binding CapacityText}" FontWeight="SemiBold" />
                                </StackPanel>
                                <StackPanel Margin="0,0,0,10">
                                    <TextBlock Text="GIÁ CƠ BẢN / ĐÊM" Style="{StaticResource FieldLabel}" />
                                    <TextBlock Text="{Binding PriceText}" FontWeight="SemiBold" />
                                </StackPanel>
                            </UniformGrid>

                            <TextBlock Text="MÔ TẢ" Style="{StaticResource FieldLabel}" Margin="0,2,0,3"
                                       Visibility="{Binding HasDescription, Converter={StaticResource BoolToVis}}" />
                            <TextBlock Text="{Binding DescriptionText}" Style="{StaticResource CaptionText}"
                                       FontSize="12" TextWrapping="Wrap"
                                       Visibility="{Binding HasDescription, Converter={StaticResource BoolToVis}}" />

                            <Border Height="1" Background="{StaticResource LineBrush}" Margin="0,16,0,14" />
                            <StackPanel Orientation="Horizontal">
                                <Button Content="Sửa" Style="{StaticResource PrimaryButton}"
                                        Padding="16,7"
                                        Command="{Binding DataContext.EditCommand,
                                                  RelativeSource={RelativeSource AncestorType=UserControl}}"
                                        CommandParameter="{Binding}" />
                                <Button Content="Xoá" Style="{StaticResource GhostButton}"
                                        Padding="14,7" Margin="8,0,0,0"
                                        Foreground="{StaticResource DangerBrush}"
                                        Command="{Binding DataContext.DeleteCommand,
                                                  RelativeSource={RelativeSource AncestorType=UserControl}}"
                                        CommandParameter="{Binding}" />
                            </StackPanel>
                        </StackPanel>
                    </StackPanel>
                </Grid>
            </Border>
        </Grid>
    </Grid>
</UserControl>
