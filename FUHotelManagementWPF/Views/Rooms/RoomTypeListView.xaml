<UserControl x:Class="FUHotelManagementWPF.Views.Rooms.RoomTypeListView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:hc="https://handyorg.github.io/handycontrol">
    <Grid Margin="0,14,0,0">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <DockPanel Grid.Row="0" Margin="0,0,0,12">
            <Button DockPanel.Dock="Right" Content="+ Thêm loại phòng"
                    Style="{StaticResource PrimaryButton}" Padding="16,8"
                    Command="{Binding AddCommand}" />
            <TextBlock VerticalAlignment="Center" Margin="2,0,0,0"
                       Style="{StaticResource CaptionText}" FontSize="12.5">
                <Run Text="{Binding TotalText, Mode=OneWay}" FontWeight="SemiBold"
                     Foreground="{StaticResource InkBrush}" />
                <Run Text=" · Xoá loại đang được phòng sử dụng sẽ chuyển sang ngừng dùng (giữ lịch sử)." />
            </TextBlock>
        </DockPanel>

        <hc:LoadingCircle Grid.Row="1" Width="34" Height="34"
                          Foreground="{StaticResource BrandBrush}"
                          Visibility="{Binding IsLoading, Converter={StaticResource BoolToVis}}" />
        <TextBlock Grid.Row="1" Text="Chưa có loại phòng nào — bấm + Thêm loại phòng để bắt đầu."
                   Style="{StaticResource CaptionText}" FontSize="13"
                   HorizontalAlignment="Center" VerticalAlignment="Center"
                   Visibility="{Binding IsEmpty, Converter={StaticResource BoolToVis}}" />

        <!-- Card-row (phuong an B) -->
        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
            <ItemsControl ItemsSource="{Binding Rows}">
                <ItemsControl.ItemTemplate>
                    <DataTemplate>
                        <Border Background="{StaticResource CardBrush}"
                                BorderBrush="{StaticResource LineBrush}" BorderThickness="1"
                                CornerRadius="12" Padding="10,8" Margin="0,0,0,8">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto" />
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                    <ColumnDefinition Width="Auto" />
                                    <ColumnDefinition Width="Auto" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>

                                <Border Grid.Column="0" Width="64" Height="46" CornerRadius="8">
                                    <Border.Background>
                                        <ImageBrush ImageSource="{Binding Thumbnail}"
                                                    Stretch="UniformToFill" />
                                    </Border.Background>
                                </Border>

                                <StackPanel Grid.Column="1" Margin="13,0,10,0"
                                            VerticalAlignment="Center">
                                    <StackPanel Orientation="Horizontal">
                                        <TextBlock Text="{Binding RoomType.TypeName}"
                                                   FontSize="14.5" FontWeight="SemiBold" />
                                        <TextBlock Text="{Binding ActiveText}"
                                                   Style="{StaticResource CaptionText}" FontSize="11"
                                                   VerticalAlignment="Center" Margin="9,1,0,0" />
                                    </StackPanel>
                                    <TextBlock Text="{Binding SubText}"
                                               Style="{StaticResource CaptionText}" FontSize="12"
                                               TextTrimming="CharacterEllipsis" Margin="0,2,0,0" />
                                </StackPanel>

                                <Border Grid.Column="2" Style="{StaticResource BadgeNeutral}"
                                        VerticalAlignment="Center" Margin="0,0,10,0">
                                    <TextBlock Text="{Binding CapacityText}" />
                                </Border>
                                <Border Grid.Column="3" Style="{StaticResource BadgeInfo}"
                                        VerticalAlignment="Center" Margin="0,0,14,0">
                                    <TextBlock Text="{Binding RoomCountText}" />
                                </Border>

                                <TextBlock Grid.Column="4" Text="{Binding PriceText}"
                                           FontWeight="SemiBold" FontSize="13"
                                           VerticalAlignment="Center" Margin="0,0,16,0" />

                                <StackPanel Grid.Column="5" Orientation="Horizontal"
                                            VerticalAlignment="Center">
                                    <Button Content="Sửa" Style="{StaticResource GhostButton}"
                                            Padding="11,5" FontSize="12"
                                            Command="{Binding DataContext.EditCommand,
                                                      RelativeSource={RelativeSource AncestorType=ItemsControl}}"
                                            CommandParameter="{Binding}" />
                                    <Button Content="Xoá" Style="{StaticResource GhostButton}"
                                            Padding="11,5" FontSize="12" Margin="6,0,0,0"
                                            Foreground="{StaticResource DangerBrush}"
                                            Command="{Binding DataContext.DeleteCommand,
                                                      RelativeSource={RelativeSource AncestorType=ItemsControl}}"
                                            CommandParameter="{Binding}" />
                                </StackPanel>
                            </Grid>
                        </Border>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>
        </ScrollViewer>
    </Grid>
</UserControl>
