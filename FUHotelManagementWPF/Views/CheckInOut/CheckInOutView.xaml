<UserControl x:Class="FUHotelManagementWPF.Views.CheckInOut.CheckInOutView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:hc="https://handyorg.github.io/handycontrol">
    <UserControl.Resources>
        <!-- Card-row dùng chung cho cả 2 cột -->
        <Style x:Key="FlowCard" TargetType="Border">
            <Setter Property="Background" Value="{StaticResource CardBrush}" />
            <Setter Property="BorderBrush" Value="{StaticResource LineBrush}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="CornerRadius" Value="4" />
            <Setter Property="Padding" Value="10,8" />
            <Setter Property="Margin" Value="0,0,0,8" />
        </Style>
    </UserControl.Resources>

    <Grid Margin="24,18,24,24">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <DockPanel Grid.Row="0" Margin="0,0,0,14">
            <Button DockPanel.Dock="Right" Content="Tải lại" Style="{StaticResource GhostButton}"
                    Padding="14,7" Command="{Binding RefreshCommand}" />
            <StackPanel>
                <TextBlock Text="Check-in / Check-out" Style="{StaticResource PageTitleText}" />
                <TextBlock Text="{Binding TodayText}" Style="{StaticResource CaptionText}"
                           FontSize="12.5" Margin="0,3,0,0" />
            </StackPanel>
        </DockPanel>

        <hc:LoadingCircle Grid.Row="1" Width="34" Height="34"
                          Foreground="{StaticResource BrandBrush}"
                          Visibility="{Binding IsLoading, Converter={StaticResource BoolToVis}}" />

        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="18" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>

            <!-- CỘT TRÁI: chờ check-in -->
            <Grid Grid.Column="0">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                </Grid.RowDefinitions>
                <TextBlock Grid.Row="0" Text="{Binding ArrivalsTitle}"
                           Style="{StaticResource SectionTitleText}" Margin="2,0,0,10" />

                <TextBlock Grid.Row="1" Text="Không có đặt phòng nào chờ check-in."
                           Style="{StaticResource CaptionText}" FontSize="12.5"
                           HorizontalAlignment="Center" Margin="0,40,0,0"
                           Visibility="{Binding IsArrivalsEmpty, Converter={StaticResource BoolToVis}}" />

                <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
                    <ItemsControl ItemsSource="{Binding Arrivals}">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Border Style="{StaticResource FlowCard}">
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="Auto" />
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="Auto" />
                                        </Grid.ColumnDefinitions>
                                        <Border Grid.Column="0" Width="58" Height="42" CornerRadius="4">
                                            <Border.Background>
                                                <ImageBrush ImageSource="{Binding Thumbnail}" Stretch="UniformToFill" />
                                            </Border.Background>
                                        </Border>
                                        <StackPanel Grid.Column="1" Margin="12,0,10,0" VerticalAlignment="Center">
                                            <StackPanel Orientation="Horizontal">
                                                <TextBlock Text="{Binding GuestName}" FontSize="14" FontWeight="SemiBold" />
                                                <Border Style="{StaticResource BadgeWarning}" Margin="8,0,0,0"
                                                        VerticalAlignment="Center"
                                                        Visibility="{Binding IsToday, Converter={StaticResource BoolToVis}}">
                                                    <TextBlock Text="{Binding DayLabel}" />
                                                </Border>
                                            </StackPanel>
                                            <TextBlock Text="{Binding SubText}" Style="{StaticResource CaptionText}"
                                                       FontSize="11.5" TextTrimming="CharacterEllipsis" Margin="0,2,0,0" />
                                            <TextBlock Text="{Binding DateText}" Style="{StaticResource CaptionText}"
                                                       FontSize="11" Margin="0,1,0,0" />
                                        </StackPanel>
                                        <Button Grid.Column="2" Content="Check-in" Style="{StaticResource PrimaryButton}"
                                                Padding="14,7" VerticalAlignment="Center"
                                                Command="{Binding DataContext.CheckInCommand,
                                                          RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                CommandParameter="{Binding}" />
                                    </Grid>
                                </Border>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </ScrollViewer>
            </Grid>

            <!-- CỘT PHẢI: đang lưu trú -->
            <Grid Grid.Column="2">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                </Grid.RowDefinitions>
                <TextBlock Grid.Row="0" Text="{Binding StaysTitle}"
                           Style="{StaticResource SectionTitleText}" Margin="2,0,0,10" />

                <TextBlock Grid.Row="1" Text="Chưa có khách nào đang lưu trú."
                           Style="{StaticResource CaptionText}" FontSize="12.5"
                           HorizontalAlignment="Center" Margin="0,40,0,0"
                           Visibility="{Binding IsStaysEmpty, Converter={StaticResource BoolToVis}}" />

                <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
                    <ItemsControl ItemsSource="{Binding Stays}">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Border Style="{StaticResource FlowCard}">
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="Auto" />
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="Auto" />
                                        </Grid.ColumnDefinitions>
                                        <Border Grid.Column="0" Width="58" Height="42" CornerRadius="4">
                                            <Border.Background>
                                                <ImageBrush ImageSource="{Binding Thumbnail}" Stretch="UniformToFill" />
                                            </Border.Background>
                                        </Border>
                                        <StackPanel Grid.Column="1" Margin="12,0,10,0" VerticalAlignment="Center">
                                            <StackPanel Orientation="Horizontal">
                                                <TextBlock Text="{Binding GuestName}" FontSize="14" FontWeight="SemiBold" />
                                                <!-- Quá hạn trả: badge đỏ để lễ tân xử lý ngay -->
                                                <Border Style="{StaticResource BadgeDanger}" Margin="8,0,0,0"
                                                        VerticalAlignment="Center"
                                                        Visibility="{Binding IsOverdue, Converter={StaticResource BoolToVis}}">
                                                    <TextBlock Text="{Binding DayLabel}" />
                                                </Border>
                                            </StackPanel>
                                            <TextBlock Text="{Binding SubText}" Style="{StaticResource CaptionText}"
                                                       FontSize="11.5" TextTrimming="CharacterEllipsis" Margin="0,2,0,0" />
                                            <TextBlock Style="{StaticResource CaptionText}" FontSize="11" Margin="0,1,0,0">
                                                <Run Text="{Binding PlannedOutText, Mode=OneWay}" />
                                                <Run Text=" · " />
                                                <Run Text="{Binding NightsText, Mode=OneWay}" />
                                            </TextBlock>
                                        </StackPanel>
                                        <Button Grid.Column="2" Content="Check-out" Style="{StaticResource GhostButton}"
                                                Padding="14,7" VerticalAlignment="Center"
                                                Command="{Binding DataContext.CheckOutCommand,
                                                          RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                CommandParameter="{Binding}" />
                                    </Grid>
                                </Border>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </ScrollViewer>
            </Grid>
        </Grid>
    </Grid>
</UserControl>
