<UserControl x:Class="FUHotelManagementWPF.Views.CheckInOut.CheckInOutView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:hc="https://handyorg.github.io/handycontrol">
    <UserControl.Resources>
        <!-- Chip lọc: chip đang chọn tô màu thương hiệu -->
        <Style x:Key="FilterChip" TargetType="Button">
            <Setter Property="Background" Value="{StaticResource CardBrush}" />
            <Setter Property="Foreground" Value="{StaticResource InkBrush}" />
            <Setter Property="Padding" Value="12,5" />
            <Setter Property="FontSize" Value="12" />
            <Setter Property="Margin" Value="0,0,7,0" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="bd" Background="{TemplateBinding Background}" CornerRadius="4"
                                BorderBrush="{StaticResource LineBrush}" BorderThickness="1"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="bd" Property="Background" Value="{StaticResource SurfaceAltBrush}" />
                            </Trigger>
                            <DataTrigger Binding="{Binding IsSelected}" Value="True">
                                <Setter TargetName="bd" Property="Background" Value="{StaticResource BrandBrush}" />
                                <Setter TargetName="bd" Property="BorderBrush" Value="{StaticResource BrandBrush}" />
                                <Setter Property="Foreground" Value="White" />
                            </DataTrigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <DataTrigger Binding="{Binding IsUrgent}" Value="True">
                    <Setter Property="Foreground" Value="{StaticResource DangerBrush}" />
                </DataTrigger>
            </Style.Triggers>
        </Style>

        <!-- Bo chrome mac dinh cua ListBoxItem, giu nguyen the card tu ve trong DataTemplate -->
        <Style x:Key="FlowItemContainer" TargetType="ListBoxItem">
            <Setter Property="Padding" Value="0" />
            <Setter Property="Margin" Value="0" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ListBoxItem">
                        <ContentPresenter />
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="PanelLabel" TargetType="TextBlock" BasedOn="{StaticResource FieldLabel}">
            <Setter Property="Margin" Value="0,0,0,2" />
        </Style>
    </UserControl.Resources>

    <Grid Margin="24,18,24,24">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <DockPanel Grid.Row="0" Margin="0,0,0,12">
            <Button DockPanel.Dock="Right" Content="Tải lại" Style="{StaticResource GhostButton}"
                    Padding="14,7" VerticalAlignment="Top" Command="{Binding RefreshCommand}" />
            <StackPanel>
                <TextBlock Text="Check-in / Check-out" Style="{StaticResource PageTitleText}" />
                <TextBlock Text="{Binding TodayText}" Style="{StaticResource CaptionText}"
                           FontSize="12.5" Margin="0,3,0,0" />
            </StackPanel>
        </DockPanel>

        <!-- Chip lọc: Tất cả / Hôm nay / Sắp đến / Đang ở / Quá hạn -->
        <ItemsControl Grid.Row="1" ItemsSource="{Binding Filters}" Margin="0,0,0,12">
            <ItemsControl.ItemsPanel>
                <ItemsPanelTemplate><WrapPanel /></ItemsPanelTemplate>
            </ItemsControl.ItemsPanel>
            <ItemsControl.ItemTemplate>
                <DataTemplate>
                    <Button Style="{StaticResource FilterChip}"
                            Command="{Binding DataContext.PickFilterCommand,
                                      RelativeSource={RelativeSource AncestorType=UserControl}}"
                            CommandParameter="{Binding}">
                        <TextBlock><Run Text="{Binding Label, Mode=OneWay}" /><Run Text=" " /><Run
                            Text="{Binding Count, Mode=OneWay}" FontWeight="SemiBold" /></TextBlock>
                    </Button>
                </DataTemplate>
            </ItemsControl.ItemTemplate>
        </ItemsControl>

        <hc:LoadingCircle Grid.Row="2" Width="34" Height="34"
                          Foreground="{StaticResource BrandBrush}"
                          Visibility="{Binding IsLoading, Converter={StaticResource BoolToVis}}" />
        <TextBlock Grid.Row="2" Text="Không có việc nào trong mục này."
                   Style="{StaticResource CaptionText}" FontSize="13"
                   HorizontalAlignment="Center" VerticalAlignment="Center"
                   Visibility="{Binding IsEmpty, Converter={StaticResource BoolToVis}}" />

        <Grid Grid.Row="2">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="1.5*" />
                <ColumnDefinition Width="16" />
                <ColumnDefinition Width="1*" />
            </Grid.ColumnDefinitions>

            <!-- CỘT TRÁI: dòng thời gian việc cần làm, quá hạn lên đầu và có vạch đỏ -->
            <ListBox Grid.Column="0" ItemsSource="{Binding ItemsView}"
                     SelectedItem="{Binding SelectedItem}"
                     ItemContainerStyle="{StaticResource FlowItemContainer}"
                     Background="Transparent" BorderThickness="0"
                     ScrollViewer.HorizontalScrollBarVisibility="Disabled">
                <ListBox.ItemTemplate>
                    <DataTemplate>
                        <Border Background="{StaticResource CardBrush}" BorderThickness="1"
                                CornerRadius="4" Padding="11,9" Margin="0,0,0,8" Cursor="Hand">
                            <Border.Style>
                                <Style TargetType="Border">
                                    <Setter Property="BorderBrush" Value="{StaticResource LineBrush}" />
                                    <Style.Triggers>
                                        <!-- Quá hạn: vạch đỏ dày bên trái để nhảy vào mắt -->
                                        <DataTrigger Binding="{Binding IsOverdue}" Value="True">
                                            <Setter Property="BorderBrush" Value="{StaticResource DangerBrush}" />
                                            <Setter Property="BorderThickness" Value="3,1,1,1" />
                                        </DataTrigger>
                                        <!-- Đang chọn: nền nhạt để biết bảng bên phải đang nói về dòng nào -->
                                        <DataTrigger Value="True" Binding="{Binding IsSelected,
                                                     RelativeSource={RelativeSource AncestorType=ListBoxItem}}">
                                            <Setter Property="Background" Value="{StaticResource BrandSoftBrush}" />
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </Border.Style>
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto" />
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>

                                <Border Grid.Column="0" Width="64" Height="46" CornerRadius="4">
                                    <Border.Background>
                                        <ImageBrush ImageSource="{Binding Thumbnail}" Stretch="UniformToFill" />
                                    </Border.Background>
                                </Border>

                                <StackPanel Grid.Column="1" Margin="13,0,10,0" VerticalAlignment="Center">
                                    <StackPanel Orientation="Horizontal">
                                        <TextBlock Text="{Binding RoomNumber}" FontSize="14.5" FontWeight="SemiBold" />
                                        <TextBlock Text=" · " Foreground="{StaticResource InkSoftBrush}" VerticalAlignment="Center" />
                                        <TextBlock Text="{Binding GuestName}" FontSize="14" VerticalAlignment="Center" />
                                    </StackPanel>
                                    <TextBlock Text="{Binding SubText}" Style="{StaticResource CaptionText}"
                                               FontSize="11.5" TextTrimming="CharacterEllipsis" Margin="0,2,0,0" />
                                </StackPanel>

                                <Border Grid.Column="2" VerticalAlignment="Center" Margin="0,0,14,0">
                                    <Border.Style>
                                        <Style TargetType="Border" BasedOn="{StaticResource BadgeBase}">
                                            <Setter Property="Background" Value="{StaticResource SurfaceAltBrush}" />
                                            <Setter Property="TextElement.Foreground" Value="{StaticResource InkSoftBrush}" />
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding IsToday}" Value="True">
                                                    <Setter Property="Background" Value="{StaticResource WarningSoftBrush}" />
                                                    <Setter Property="TextElement.Foreground" Value="{StaticResource WarningBrush}" />
                                                </DataTrigger>
                                                <DataTrigger Binding="{Binding IsOverdue}" Value="True">
                                                    <Setter Property="Background" Value="{StaticResource DangerSoftBrush}" />
                                                    <Setter Property="TextElement.Foreground" Value="{StaticResource DangerBrush}" />
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </Border.Style>
                                    <TextBlock Text="{Binding StatusText}" />
                                </Border>

                                <!-- Nút làm ngay trên dòng, không phải chọn rồi mới làm được.
                                     Dòng quá hạn có thêm nút phụ vì đó là lúc cần xử lý khác đi:
                                     khách không tới thì đánh dấu Không đến, khách ở thêm thì gia hạn. -->
                                <StackPanel Grid.Column="3" Orientation="Horizontal" VerticalAlignment="Center">
                                    <Button Content="Không đến" Style="{StaticResource GhostButton}"
                                            Padding="11,7" Margin="0,0,6,0" FontSize="12"
                                            Foreground="{StaticResource DangerBrush}"
                                            Visibility="{Binding ShowNoShow, Converter={StaticResource BoolToVis}}"
                                            ToolTip="Khách không tới — giải phóng phòng để bán cho khách khác"
                                            Command="{Binding DataContext.NoShowCommand,
                                                      RelativeSource={RelativeSource AncestorType=UserControl}}"
                                            CommandParameter="{Binding}" />
                                    <Button Content="Huỷ" Style="{StaticResource GhostButton}"
                                            Padding="11,7" Margin="0,0,6,0" FontSize="12"
                                            Visibility="{Binding ShowCancel, Converter={StaticResource BoolToVis}}"
                                            ToolTip="Khách báo không tới nữa — huỷ hẳn đơn"
                                            Command="{Binding DataContext.CancelCommand,
                                                      RelativeSource={RelativeSource AncestorType=UserControl}}"
                                            CommandParameter="{Binding}" />
                                    <Button Content="Gia hạn" Style="{StaticResource GhostButton}"
                                            Padding="11,7" Margin="0,0,6,0" FontSize="12"
                                            Visibility="{Binding ShowExtendOnRow, Converter={StaticResource BoolToVis}}"
                                            ToolTip="Khách muốn ở thêm — đổi ngày trả"
                                            Command="{Binding DataContext.ExtendCommand,
                                                      RelativeSource={RelativeSource AncestorType=UserControl}}"
                                            CommandParameter="{Binding}" />
                                    <Button Content="{Binding ActionLabel}"
                                            Style="{StaticResource PrimaryButton}" Padding="14,7"
                                            Command="{Binding DataContext.ActionCommand,
                                                      RelativeSource={RelativeSource AncestorType=UserControl}}"
                                            CommandParameter="{Binding}" />
                                </StackPanel>
                            </Grid>
                        </Border>
                    </DataTemplate>
                </ListBox.ItemTemplate>
            </ListBox>

            <!-- CỘT PHẢI: bảng làm việc, xem đủ thông tin và tiền trước khi bấm -->
            <Border Grid.Column="2" Style="{StaticResource Card}" Padding="0"
                    Effect="{StaticResource SoftShadow}" VerticalAlignment="Top">
                <Grid>
                    <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center" Margin="20,60"
                                TextElement.Foreground="{StaticResource InkSoftBrush}">
                        <StackPanel.Style>
                            <Style TargetType="StackPanel">
                                <Setter Property="Visibility" Value="Visible" />
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding HasSelection}" Value="True">
                                        <Setter Property="Visibility" Value="Collapsed" />
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </StackPanel.Style>
                        <TextBlock Text="&#xE8BD;" Style="{StaticResource IconText}" FontSize="26"
                                   HorizontalAlignment="Center" />
                        <TextBlock Text="Chọn một việc để xem chi tiết và tiền tạm tính"
                                   Style="{StaticResource CaptionText}" FontSize="12.5"
                                   TextWrapping="Wrap" TextAlignment="Center" Margin="0,10,0,0" MaxWidth="200" />
                    </StackPanel>

                    <StackPanel DataContext="{Binding SelectedItem}">
                        <StackPanel.Style>
                            <Style TargetType="StackPanel">
                                <Setter Property="Visibility" Value="Collapsed" />
                                <Style.Triggers>
                                    <DataTrigger Value="True" Binding="{Binding DataContext.HasSelection,
                                                 RelativeSource={RelativeSource AncestorType=UserControl}}">
                                        <Setter Property="Visibility" Value="Visible" />
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </StackPanel.Style>

                        <Border Height="112" CornerRadius="4,4,0,0">
                            <Border.Background>
                                <ImageBrush ImageSource="{Binding Thumbnail}" Stretch="UniformToFill" />
                            </Border.Background>
                            <Grid>
                                <Border Style="{StaticResource TileShade}" CornerRadius="4,4,0,0" />
                                <TextBlock Text="{Binding HeaderText}" Style="{StaticResource TileName}"
                                           FontSize="16" VerticalAlignment="Bottom" Margin="14,0,14,11" />
                            </Grid>
                        </Border>

                        <StackPanel Margin="16,14,16,16">
                            <UniformGrid Columns="2">
                                <StackPanel Margin="0,0,0,11">
                                    <TextBlock Text="KHÁCH" Style="{StaticResource PanelLabel}" />
                                    <TextBlock Text="{Binding GuestName}" FontWeight="SemiBold"
                                               TextTrimming="CharacterEllipsis" />
                                </StackPanel>
                                <StackPanel Margin="0,0,0,11">
                                    <TextBlock Text="ĐIỆN THOẠI" Style="{StaticResource PanelLabel}" />
                                    <TextBlock Text="{Binding GuestPhone}" FontWeight="SemiBold" />
                                </StackPanel>
                                <StackPanel Margin="0,0,0,11">
                                    <TextBlock Text="{Binding CheckInLabel}" Style="{StaticResource PanelLabel}" />
                                    <TextBlock Text="{Binding CheckInValue}" FontWeight="SemiBold" />
                                </StackPanel>
                                <StackPanel Margin="0,0,0,11">
                                    <TextBlock Text="DỰ KIẾN TRẢ" Style="{StaticResource PanelLabel}" />
                                    <TextBlock Text="{Binding PlannedOutText}" FontWeight="SemiBold" />
                                </StackPanel>
                                <StackPanel>
                                    <TextBlock Text="SỐ KHÁCH" Style="{StaticResource PanelLabel}" />
                                    <TextBlock Text="{Binding GuestCountText}" FontWeight="SemiBold" />
                                </StackPanel>
                                <StackPanel>
                                    <TextBlock Text="MÃ ĐẶT" Style="{StaticResource PanelLabel}" />
                                    <TextBlock Text="{Binding BookingCode}" FontWeight="SemiBold"
                                               TextTrimming="CharacterEllipsis" />
                                </StackPanel>
                            </UniformGrid>

                            <TextBlock Text="{Binding SpecialRequests}" Style="{StaticResource CaptionText}"
                                       FontSize="11.5" TextWrapping="Wrap" Margin="0,12,0,0"
                                       Visibility="{Binding HasSpecialRequests, Converter={StaticResource BoolToVis}}" />

                            <!-- Tiền: lễ tân thấy trước khi bấm, không bấm mù như trước -->
                            <Border Background="{StaticResource SurfaceAltBrush}" CornerRadius="4"
                                    Padding="12,10" Margin="0,14,0,0">
                                <StackPanel>
                                    <DockPanel>
                                        <TextBlock DockPanel.Dock="Right" Text="{Binding RoomChargeText}"
                                                   FontWeight="SemiBold" />
                                        <TextBlock Text="{Binding NightsText}" Style="{StaticResource CaptionText}"
                                                   FontSize="11.5" />
                                    </DockPanel>
                                    <TextBlock Text="{Binding ExtraNightsText}" FontSize="11"
                                               Foreground="{StaticResource DangerBrush}" Margin="0,4,0,0"
                                               Visibility="{Binding HasExtraNights, Converter={StaticResource BoolToVis}}" />
                                    <DockPanel Margin="0,6,0,0"
                                               Visibility="{Binding HasSurcharge, Converter={StaticResource BoolToVis}}">
                                        <TextBlock DockPanel.Dock="Right" Text="{Binding SurchargeText}"
                                                   FontWeight="SemiBold" />
                                        <TextBlock Text="Phụ thu (hỏng / mất đồ)" Style="{StaticResource CaptionText}"
                                                   FontSize="11.5" />
                                    </DockPanel>
                                    <DockPanel Margin="0,6,0,0">
                                        <TextBlock DockPanel.Dock="Right" Text="chưa có"
                                                   Style="{StaticResource CaptionText}" FontSize="11.5" />
                                        <TextBlock Text="Dịch vụ đã dùng" Style="{StaticResource CaptionText}"
                                                   FontSize="11.5" />
                                    </DockPanel>
                                    <Border Height="1" Background="{StaticResource LineBrush}" Margin="0,9,0,8" />
                                    <DockPanel>
                                        <TextBlock DockPanel.Dock="Right" Text="{Binding TotalChargeText}"
                                                   FontSize="15" FontWeight="SemiBold"
                                                   Foreground="{StaticResource BrandBrush}" />
                                        <TextBlock Text="{Binding EstimateLabel}" VerticalAlignment="Center" />
                                    </DockPanel>
                                </StackPanel>
                            </Border>
                            <TextBlock Text="Tiền dịch vụ sẽ cộng vào khi module Dịch vụ xong. Hoá đơn chính thức lập ở màn Hoá đơn."
                                       Style="{StaticResource CaptionText}" FontSize="11" TextWrapping="Wrap"
                                       Margin="0,7,0,0" />

                            <!-- Hai việc phải làm được TRƯỚC khi check-out -->
                            <UniformGrid Columns="2" Margin="0,14,0,0"
                                         Visibility="{Binding CanExtend, Converter={StaticResource BoolToVis}}">
                                <Button Content="Gia hạn" Style="{StaticResource GhostButton}"
                                        Padding="0,8" Margin="0,0,5,0"
                                        Command="{Binding DataContext.ExtendCommand,
                                                  RelativeSource={RelativeSource AncestorType=UserControl}}"
                                        CommandParameter="{Binding}" />
                                <Button Content="Kiểm đồ / phụ thu" Style="{StaticResource GhostButton}"
                                        Padding="0,8" Margin="5,0,0,0"
                                        Command="{Binding DataContext.SurchargeCommand,
                                                  RelativeSource={RelativeSource AncestorType=UserControl}}"
                                        CommandParameter="{Binding}" />
                            </UniformGrid>

                            <!-- Khách quá hạn đến: xử lý được ngay ở đây, không phải sang màn Đặt phòng -->
                            <UniformGrid Columns="2" Margin="0,14,0,0"
                                         Visibility="{Binding ShowNoShow, Converter={StaticResource BoolToVis}}">
                                <Button Content="Không đến" Style="{StaticResource GhostButton}"
                                        Padding="0,8" Margin="0,0,5,0"
                                        Foreground="{StaticResource DangerBrush}"
                                        Command="{Binding DataContext.NoShowCommand,
                                                  RelativeSource={RelativeSource AncestorType=UserControl}}"
                                        CommandParameter="{Binding}" />
                                <Button Content="Huỷ đơn" Style="{StaticResource GhostButton}"
                                        Padding="0,8" Margin="5,0,0,0"
                                        Command="{Binding DataContext.CancelCommand,
                                                  RelativeSource={RelativeSource AncestorType=UserControl}}"
                                        CommandParameter="{Binding}" />
                            </UniformGrid>

                            <Button Content="{Binding ActionLabel}" Style="{StaticResource PrimaryButton}"
                                    Padding="0,10" Margin="0,8,0,0" FontSize="13.5"
                                    Command="{Binding DataContext.ActionCommand,
                                              RelativeSource={RelativeSource AncestorType=UserControl}}"
                                    CommandParameter="{Binding}" />
                        </StackPanel>
                    </StackPanel>
                </Grid>
            </Border>
        </Grid>
    </Grid>
</UserControl>
