<Window x:Class="FUHotelManagementWPF.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:hc="https://handyorg.github.io/handycontrol"
        xmlns:vm="clr-namespace:FUHotelManagementWPF.ViewModels"
        Title="FU Hotel Management"
        Height="760" Width="1220"
        MinHeight="680" MinWidth="1100"
        WindowStartupLocation="CenterScreen"
        Style="{StaticResource BaseWindow}">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <!-- Thanh tren: logo + breadcrumb + user chip + dang xuat -->
        <Border Grid.Row="0" Background="{StaticResource CardBrush}"
                BorderBrush="{StaticResource LineBrush}" BorderThickness="0,0,0,1"
                Padding="20,10">
            <DockPanel>
                <StackPanel Orientation="Horizontal" DockPanel.Dock="Left">
                    <Border Width="32" Height="32" CornerRadius="999"
                            Background="{StaticResource BrandBrush}">
                        <TextBlock Text="FU" Foreground="White" FontWeight="Bold" FontSize="12"
                                   HorizontalAlignment="Center" VerticalAlignment="Center" />
                    </Border>
                    <TextBlock Text="FU Hotel Management" FontSize="15.5" FontWeight="Bold"
                               VerticalAlignment="Center" Margin="10,0,0,0" />
                    <TextBlock Text="{Binding Breadcrumb}" Style="{StaticResource CaptionText}"
                               FontSize="12.5" VerticalAlignment="Center" Margin="22,1,0,0" />
                </StackPanel>

                <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                    <!-- User chip -->
                    <Border CornerRadius="4" Background="{StaticResource SurfaceBrush}"
                            BorderBrush="{StaticResource LineBrush}" BorderThickness="1"
                            Padding="5,4" Margin="0,0,10,0">
                        <StackPanel Orientation="Horizontal">
                            <Border Width="27" Height="27" CornerRadius="999"
                                    Background="{StaticResource BrandBrush}">
                                <TextBlock Text="{Binding AvatarInitial}" Foreground="White"
                                           FontWeight="Bold" FontSize="12"
                                           HorizontalAlignment="Center" VerticalAlignment="Center" />
                            </Border>
                            <StackPanel Margin="9,0,11,0" VerticalAlignment="Center">
                                <TextBlock Text="{Binding GreetingName}" FontWeight="SemiBold"
                                           FontSize="12" />
                                <TextBlock Text="{Binding RoleDisplay}"
                                           Style="{StaticResource CaptionText}" FontSize="10.5" />
                            </StackPanel>
                        </StackPanel>
                    </Border>
                    <Button Content="Đăng xuất" Style="{StaticResource GhostButton}"
                            VerticalAlignment="Center"
                            Command="{Binding LogoutCommand}" />
                </StackPanel>
            </DockPanel>
        </Border>

        <!-- Than: nav trai (nhom 4 cum) + vung noi dung -->
        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="238" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>

            <Border Grid.Column="0" Background="{StaticResource SurfaceAltBrush}"
                    BorderBrush="{StaticResource LineBrush}" BorderThickness="0,0,1,0">
                <ListBox ItemsSource="{Binding ModulesView}"
                         SelectedItem="{Binding SelectedModule}"
                         ItemContainerStyle="{StaticResource NavItem}"
                         Background="Transparent" BorderThickness="0"
                         Margin="10,6,10,16"
                         ScrollViewer.HorizontalScrollBarVisibility="Disabled">
                    <ListBox.GroupStyle>
                        <GroupStyle>
                            <GroupStyle.HeaderTemplate>
                                <DataTemplate>
                                    <TextBlock Text="{Binding Name}" FontSize="10" FontWeight="Bold"
                                               Foreground="{StaticResource InkSoftBrush}"
                                               Opacity="0.9" Margin="16,16,0,5" />
                                </DataTemplate>
                            </GroupStyle.HeaderTemplate>
                        </GroupStyle>
                    </ListBox.GroupStyle>
                    <ListBox.ItemTemplate>
                        <DataTemplate DataType="{x:Type vm:ModuleItem}">
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="{Binding Icon}" Style="{StaticResource IconText}" />
                                <TextBlock Text="{Binding Title}" Margin="11,0,0,0"
                                           VerticalAlignment="Center" />
                            </StackPanel>
                        </DataTemplate>
                    </ListBox.ItemTemplate>
                </ListBox>
            </Border>

            <!-- Vung noi dung ViewModel-first: WPF tu chon View theo ViewMappings.xaml.
                 Quy uoc PageHeader: hang dau moi View = PageTitleText + nut hanh dong ben phai -->
            <ContentControl Grid.Column="1" Content="{Binding CurrentViewModel}"
                            Focusable="False" />
        </Grid>

        <!-- Panel nhan thong bao Notify.* (Growl) - goc phai tren, khong che nut -->
        <StackPanel Grid.Row="1" hc:Growl.GrowlParent="True"
                    VerticalAlignment="Top" HorizontalAlignment="Right"
                    Margin="0,10,10,0" Panel.ZIndex="999" />
    </Grid>
</Window>
