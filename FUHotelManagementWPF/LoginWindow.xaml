<Window x:Class="FUHotelManagementWPF.LoginWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="FU Hotel — Đăng nhập"
        Height="600" Width="960"
        WindowStartupLocation="CenterScreen"
        ResizeMode="CanMinimize"
        Style="{StaticResource BaseWindow}">
    <!-- L2: anh sanh phu TOAN cua so + overlay toi, card dang nhap noi lech phai -->
    <Grid>
        <Grid.Background>
            <ImageBrush ImageSource="pack://application:,,,/Assets/Brand/login-side-1.jpg"
                        Stretch="UniformToFill" />
        </Grid.Background>

        <!-- Overlay toi: dam ben trai (cho chu thuong hieu), nhat dan sang phai -->
        <Grid>
            <Grid.Background>
                <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                    <GradientStop Color="#E01B2E22" Offset="0" />
                    <GradientStop Color="#B0223A2B" Offset="0.5" />
                    <GradientStop Color="#66223A2B" Offset="1" />
                </LinearGradientBrush>
            </Grid.Background>
        </Grid>

        <!-- Chu thuong hieu goc trai -->
        <StackPanel VerticalAlignment="Center" HorizontalAlignment="Left"
                    Margin="56,0,0,0" MaxWidth="360">
            <Border Width="50" Height="50" CornerRadius="999" Background="White"
                    HorizontalAlignment="Left">
                <TextBlock Text="FU" Foreground="{StaticResource BrandDarkBrush}"
                           FontWeight="Bold" FontSize="17"
                           HorizontalAlignment="Center" VerticalAlignment="Center" />
            </Border>
            <TextBlock Text="FU Hotel Management" Foreground="White"
                       FontSize="30" FontWeight="Bold" Margin="0,18,0,10" />
            <TextBlock Foreground="#D6FFFFFF" FontSize="13.5" TextWrapping="Wrap" LineHeight="21"
                       Text="Hệ thống quản lý khách sạn cho đội ngũ vận hành — đặt phòng, check-in/out, dịch vụ và hoá đơn trong một nơi." />
            <TextBlock Text="Đồ án PRN212 · Nhóm 2 · SE1919"
                       Foreground="#99FFFFFF" FontSize="11.5" Margin="0,22,0,0" />
        </StackPanel>

        <!-- Card dang nhap noi lech phai -->
        <Border Background="{StaticResource CardBrush}" CornerRadius="4"
                Effect="{StaticResource SoftShadowLarge}"
                Width="360" VerticalAlignment="Center" HorizontalAlignment="Right"
                Margin="0,0,56,0" Padding="34,32">
            <StackPanel>
                <TextBlock Text="Đăng nhập" Style="{StaticResource PageTitleText}" />
                <TextBlock Text="Dùng tài khoản nhân viên được cấp để vào hệ thống."
                           Style="{StaticResource CaptionText}" FontSize="12.5"
                           Margin="0,7,0,26" />

                <TextBlock Text="EMAIL" Style="{StaticResource FieldLabel}" />
                <TextBox Style="{StaticResource InputBox}"
                         Text="{Binding Email, UpdateSourceTrigger=PropertyChanged, ValidatesOnNotifyDataErrors=True}" />

                <TextBlock Text="MẬT KHẨU" Style="{StaticResource FieldLabel}" Margin="0,16,0,5" />
                <PasswordBox x:Name="PasswordInput" Style="{StaticResource InputPasswordBox}" />

                <!-- Dong bao loi: icon canh bao + chu do -->
                <Border Margin="0,12,0,0" CornerRadius="4" Padding="10,8"
                        Background="{StaticResource DangerSoftBrush}">
                    <Border.Style>
                        <Style TargetType="Border">
                            <Setter Property="Visibility" Value="Visible" />
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding ErrorMessage}" Value="">
                                    <Setter Property="Visibility" Value="Collapsed" />
                                </DataTrigger>
                                <DataTrigger Binding="{Binding ErrorMessage}" Value="{x:Null}">
                                    <Setter Property="Visibility" Value="Collapsed" />
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </Border.Style>
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="&#xE7BA;" Style="{StaticResource IconText}"
                                   Foreground="{StaticResource DangerBrush}"
                                   VerticalAlignment="Top" Margin="0,2,8,0" />
                        <TextBlock Text="{Binding ErrorMessage}" Foreground="{StaticResource DangerBrush}"
                                   TextWrapping="Wrap" MaxWidth="250" />
                    </StackPanel>
                </Border>

                <Button Content="Đăng nhập" Style="{StaticResource PrimaryButton}"
                        Margin="0,24,0,0" IsDefault="True"
                        HorizontalContentAlignment="Center"
                        Command="{Binding LoginCommand}"
                        CommandParameter="{Binding ElementName=PasswordInput}" />

                <!-- Khong bay mat khau ra man dang nhap nua: mat khau admin gio lay tu
                     appsettings.Local.json rieng tung may nen ghi cung o day la sai. -->
                <!-- Tai khoan demo cua do an, de san cho ca nhom vao nhanh.
                     Ai muon mat khau rieng thi de trong appsettings.Local.json, no se ghi de. -->
                <Border Background="{StaticResource SurfaceAltBrush}" CornerRadius="4"
                        Padding="11,8" Margin="0,16,0,0">
                    <StackPanel>
                        <TextBlock Text="Tài khoản demo" Style="{StaticResource FieldLabel}"
                                   HorizontalAlignment="Center" />
                        <TextBlock HorizontalAlignment="Center" Margin="0,4,0,0" FontSize="12.5">
                            <Run Text="admin@hotel.com" FontWeight="SemiBold" /><Run
                            Text="  ·  " Foreground="{StaticResource InkSoftBrush}" /><Run
                            Text="FuHotel@2026" FontWeight="SemiBold" />
                        </TextBlock>
                    </StackPanel>
                </Border>
            </StackPanel>
        </Border>
    </Grid>
</Window>
