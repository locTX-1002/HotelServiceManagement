<Window x:Class="FUHotelManagementWPF.LoginWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="FU Hotel — Đăng nhập"
        Height="600" Width="460"
        WindowStartupLocation="CenterScreen"
        ResizeMode="NoResize"
        Style="{StaticResource BaseWindow}">
    <Grid>
        <Border Background="{StaticResource CardBrush}"
                BorderBrush="{StaticResource LineBrush}" BorderThickness="1"
                CornerRadius="18" Margin="40" Padding="34,38"
                VerticalAlignment="Center">
            <StackPanel>

                <!-- Logo + ten he thong -->
                <Border Width="58" Height="58" CornerRadius="999"
                        Background="{StaticResource BrandBrush}" HorizontalAlignment="Center">
                    <TextBlock Text="FU" Foreground="White" FontWeight="Bold" FontSize="20"
                               HorizontalAlignment="Center" VerticalAlignment="Center" />
                </Border>
                <TextBlock Text="FU Hotel Management" FontSize="22" FontWeight="Bold"
                           HorizontalAlignment="Center" Margin="0,14,0,3" />
                <TextBlock Text="Hệ thống quản lý khách sạn"
                           Foreground="{StaticResource InkSoftBrush}"
                           HorizontalAlignment="Center" Margin="0,0,0,26" />

                <!-- Form -->
                <TextBlock Text="EMAIL" Style="{StaticResource FieldLabel}" />
                <TextBox Style="{StaticResource InputBox}"
                         Text="{Binding Email, UpdateSourceTrigger=PropertyChanged}" />

                <TextBlock Text="MẬT KHẨU" Style="{StaticResource FieldLabel}" Margin="0,16,0,5" />
                <PasswordBox x:Name="PasswordInput" Style="{StaticResource InputPasswordBox}" />

                <!-- Dong bao loi: icon canh bao + chu do, chi hien khi co noi dung -->
                <Border Margin="0,12,0,0" CornerRadius="8" Padding="10,8"
                        Background="{StaticResource DangerSoftBrush}">
                    <Border.Style>
                        <Style TargetType="Border">
                            <Setter Property="Visibility" Value="Visible" />
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding ErrorMessage}" Value="">
                                    <Setter Property="Visibility" Value="Collapsed" />
                                </DataTrigger>
                                <DataTrigger Binding="{Binding ErrorMessage}" Value="{x:Null}">
                                    <Setter Property="Visibility" Value="Collapsed" />
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </Border.Style>
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="&#xE7BA;" Style="{StaticResource IconText}"
                                   Foreground="{StaticResource DangerBrush}"
                                   VerticalAlignment="Top" Margin="0,2,8,0" />
                        <TextBlock Text="{Binding ErrorMessage}" Foreground="{StaticResource DangerBrush}"
                                   TextWrapping="Wrap" MaxWidth="290" />
                    </StackPanel>
                </Border>

                <Button Content="Đăng nhập" Style="{StaticResource PrimaryButton}"
                        Margin="0,22,0,0" IsDefault="True"
                        Command="{Binding LoginCommand}"
                        CommandParameter="{Binding ElementName=PasswordInput}" />

                <!-- Goi y tai khoan seed cho team chay lan dau -->
                <TextBlock HorizontalAlignment="Center" Margin="0,18,0,0" FontSize="11.5"
                           Foreground="{StaticResource InkSoftBrush}">
                    Tài khoản mẫu: admin@hotel.com / Admin123!
                </TextBlock>

            </StackPanel>
        </Border>
    </Grid>
</Window>
