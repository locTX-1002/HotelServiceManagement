<Window x:Class="FUHotelManagementWPF.LoginWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="FU Hotel — Đăng nhập"
        Height="560" Width="920"
        WindowStartupLocation="CenterScreen"
        ResizeMode="CanMinimize"
        Style="{StaticResource BaseWindow}">
    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="5*" />
            <ColumnDefinition Width="6*" />
        </Grid.ColumnDefinitions>

        <!-- Panel thuong hieu ben trai -->
        <Border Grid.Column="0">
            <Border.Background>
                <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                    <GradientStop Color="#27492D" Offset="0" />
                    <GradientStop Color="#34613C" Offset="0.65" />
                    <GradientStop Color="#3E6E46" Offset="1" />
                </LinearGradientBrush>
            </Border.Background>
            <Grid ClipToBounds="True">
                <!-- Hoa tiet hinh hoc mo -->
                <Ellipse Width="380" Height="380" Fill="#12FFFFFF"
                         HorizontalAlignment="Right" VerticalAlignment="Top" Margin="0,-140,-140,0" />
                <Ellipse Width="240" Height="240" Fill="#0DFFFFFF"
                         HorizontalAlignment="Left" VerticalAlignment="Bottom" Margin="-80,0,0,-80" />
                <Ellipse Width="120" Height="120" Stroke="#22FFFFFF" StrokeThickness="1.5"
                         HorizontalAlignment="Right" VerticalAlignment="Bottom" Margin="0,0,60,90" />

                <StackPanel VerticalAlignment="Center" Margin="46,0,40,0">
                    <Border Width="54" Height="54" CornerRadius="999" Background="White"
                            HorizontalAlignment="Left">
                        <TextBlock Text="FU" Foreground="{StaticResource BrandDarkBrush}"
                                   FontWeight="Bold" FontSize="18"
                                   HorizontalAlignment="Center" VerticalAlignment="Center" />
                    </Border>
                    <TextBlock Text="FU Hotel Management" Foreground="White"
                               FontSize="27" FontWeight="Bold" Margin="0,20,0,8" />
                    <TextBlock Foreground="#CCFFFFFF" FontSize="13" TextWrapping="Wrap" LineHeight="20"
                               Text="Hệ thống quản lý khách sạn cho đội ngũ vận hành — đặt phòng, check-in/out, dịch vụ và hoá đơn trong một nơi." />
                </StackPanel>

                <TextBlock Text="Đồ án PRN212 · Nhóm 2 · SE1919"
                           Foreground="#8CFFFFFF" FontSize="11.5"
                           VerticalAlignment="Bottom" HorizontalAlignment="Left"
                           Margin="46,0,0,26" />
            </Grid>
        </Border>

        <!-- Form dang nhap ben phai -->
        <Grid Grid.Column="1" Background="{StaticResource CardBrush}">
            <StackPanel Width="330" VerticalAlignment="Center">
                <TextBlock Text="Đăng nhập" Style="{StaticResource PageTitleText}" />
                <TextBlock Text="Dùng tài khoản nhân viên được cấp để vào hệ thống."
                           Style="{StaticResource CaptionText}" FontSize="12.5"
                           Margin="0,7,0,28" />

                <TextBlock Text="EMAIL" Style="{StaticResource FieldLabel}" />
                <!-- ValidatesOnNotifyDataErrors: o tu vien do khi ViewModel AddError("Email", ...) -->
                <TextBox Style="{StaticResource InputBox}"
                         Text="{Binding Email, UpdateSourceTrigger=PropertyChanged, ValidatesOnNotifyDataErrors=True}" />

                <TextBlock Text="MẬT KHẨU" Style="{StaticResource FieldLabel}" Margin="0,16,0,5" />
                <PasswordBox x:Name="PasswordInput" Style="{StaticResource InputPasswordBox}" />

                <!-- Dong bao loi: icon canh bao + chu do, chi hien khi co noi dung -->
                <Border Margin="0,12,0,0" CornerRadius="8" Padding="10,8"
                        Background="{StaticResource DangerSoftBrush}">
                    <Border.Style>
                        <Style TargetType="Border">
                            <Setter Property="Visibility" Value="Visible" />
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding ErrorMessage}" Value="">
                                    <Setter Property="Visibility" Value="Collapsed" />
                                </DataTrigger>
                                <DataTrigger Binding="{Binding ErrorMessage}" Value="{x:Null}">
                                    <Setter Property="Visibility" Value="Collapsed" />
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </Border.Style>
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="&#xE7BA;" Style="{StaticResource IconText}"
                                   Foreground="{StaticResource DangerBrush}"
                                   VerticalAlignment="Top" Margin="0,2,8,0" />
                        <TextBlock Text="{Binding ErrorMessage}" Foreground="{StaticResource DangerBrush}"
                                   TextWrapping="Wrap" MaxWidth="280" />
                    </StackPanel>
                </Border>

                <Button Content="Đăng nhập" Style="{StaticResource PrimaryButton}"
                        Margin="0,24,0,0" IsDefault="True"
                        HorizontalContentAlignment="Center"
                        Command="{Binding LoginCommand}"
                        CommandParameter="{Binding ElementName=PasswordInput}" />

                <!-- Goi y tai khoan seed cho team chay lan dau -->
                <TextBlock HorizontalAlignment="Center" Margin="0,18,0,0"
                           Style="{StaticResource CaptionText}" FontSize="11.5"
                           Text="Tài khoản mẫu: admin@hotel.com / Admin123!" />
            </StackPanel>
        </Grid>
    </Grid>
</Window>
