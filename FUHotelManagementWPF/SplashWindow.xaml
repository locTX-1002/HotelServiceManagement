<Window x:Class="FUHotelManagementWPF.SplashWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:hc="https://handyorg.github.io/handycontrol"
        Title="FU Hotel Management"
        Width="400" Height="230"
        WindowStyle="None" AllowsTransparency="True" Background="Transparent"
        WindowStartupLocation="CenterScreen" ResizeMode="NoResize"
        ShowInTaskbar="False" Topmost="True">
    <!-- Splash nhe hien trong luc EnsureMigrated chay nen (lan dau tao DB mat vai giay) -->
    <Border Background="{StaticResource CardBrush}" CornerRadius="18"
            BorderBrush="{StaticResource LineBrush}" BorderThickness="1">
        <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center">
            <Border Width="50" Height="50" CornerRadius="999"
                    Background="{StaticResource BrandBrush}" HorizontalAlignment="Center">
                <TextBlock Text="FU" Foreground="White" FontWeight="Bold" FontSize="17"
                           HorizontalAlignment="Center" VerticalAlignment="Center" />
            </Border>
            <TextBlock Text="FU Hotel Management" FontSize="16" FontWeight="Bold"
                       HorizontalAlignment="Center" Margin="0,12,0,2" />
            <TextBlock Text="Đang chuẩn bị cơ sở dữ liệu…" Style="{StaticResource CaptionText}"
                       HorizontalAlignment="Center" />
            <hc:LoadingCircle Width="30" Height="30" Margin="0,16,0,0"
                              Foreground="{StaticResource BrandBrush}" />
        </StackPanel>
    </Border>
</Window>
