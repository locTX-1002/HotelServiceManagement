<Application x:Class="FUHotelManagementWPF.App"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <!-- Khong dat StartupUri: App.xaml.cs hien splash, chuan bi database xong moi mo LoginWindow -->
    <Application.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <!-- Theme HandyControl (DataGrid, ComboBox, DatePicker, Growl... dep san) -->
                <ResourceDictionary Source="pack://application:,,,/HandyControl;component/Themes/SkinDefault.xaml" />
                <ResourceDictionary Source="pack://application:,,,/HandyControl;component/Themes/Theme.xaml" />
                <!-- Design tokens cua nhom - merge SAU HandyControl de ghi de mau thuong hieu.
                     Quy uoc: module chi dung brush/style tu 3 file nay, khong hardcode. -->
                <ResourceDictionary Source="Themes/Colors.xaml" />
                <ResourceDictionary Source="Themes/Typography.xaml" />
                <ResourceDictionary Source="Themes/Controls.xaml" />
                <!-- Dang ky View cho ViewModel - moi module them 1 dong trong file nay -->
                <ResourceDictionary Source="Views/ViewMappings.xaml" />
            </ResourceDictionary.MergedDictionaries>

            <!-- Nen + chu mac dinh cho moi cua so -->
            <Style x:Key="BaseWindow" TargetType="Window">
                <Setter Property="FontFamily" Value="Segoe UI" />
                <Setter Property="FontSize" Value="13" />
                <Setter Property="Background" Value="{StaticResource SurfaceBrush}" />
                <Setter Property="Foreground" Value="{StaticResource InkBrush}" />
                <!-- Keo cac canh ve dung diem anh, khong thi vien va duong ke bi mo nua pixel -->
                <Setter Property="UseLayoutRounding" Value="True" />
                <!-- Anh phong to nho lai bang thuat toan tot nhat: anh phong 1600px thu
                     xuong o 58px ma dung che do mac dinh se ram va rang cua -->
                <Setter Property="RenderOptions.BitmapScalingMode" Value="HighQuality" />
            </Style>
        </ResourceDictionary>
    </Application.Resources>
</Application>
