<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <!-- ============================================================
         DESIGN TOKENS: MAU SAC - nguon chan ly duy nhat cho ca app.
         Bang mau "Xanh reu & xuong da": nen da sang hoi lanh, chu ink reu,
         nhan xanh reu dam - hospitality cao cap, diu mat khi dung lau.
         QUY UOC CHO CA NHOM: chi dung brush theo ten o day,
         KHONG hardcode ma mau hex trong XAML cua module.
         ============================================================ -->

    <!-- Thuong hieu -->
    <SolidColorBrush x:Key="BrandBrush" Color="#34613C" />
    <SolidColorBrush x:Key="BrandDarkBrush" Color="#27492D" />
    <SolidColorBrush x:Key="BrandLightBrush" Color="#4E7D55" />
    <!-- Nen nhat cho item dang chon / hover khu vuc brand -->
    <SolidColorBrush x:Key="BrandSoftBrush" Color="#E2EAE0" />

    <!-- Trung tinh -->
    <SolidColorBrush x:Key="SurfaceBrush" Color="#F3F4F0" />
    <SolidColorBrush x:Key="SurfaceAltBrush" Color="#E9EBE4" />
    <SolidColorBrush x:Key="CardBrush" Color="#FCFCFA" />
    <SolidColorBrush x:Key="InkBrush" Color="#1D231D" />
    <SolidColorBrush x:Key="InkSoftBrush" Color="#646B5E" />
    <SolidColorBrush x:Key="LineBrush" Color="#1F000000" />

    <!-- Trang thai: dung cho badge, canh bao, thong bao.
         Ban dam = chu/icon, ban Soft = nen pill -->
    <SolidColorBrush x:Key="SuccessBrush" Color="#2E7D32" />
    <SolidColorBrush x:Key="SuccessSoftBrush" Color="#E3F1E4" />
    <SolidColorBrush x:Key="WarningBrush" Color="#B45309" />
    <SolidColorBrush x:Key="WarningSoftBrush" Color="#FBEED9" />
    <SolidColorBrush x:Key="DangerBrush" Color="#B3261E" />
    <SolidColorBrush x:Key="DangerSoftBrush" Color="#F9E3E1" />
    <SolidColorBrush x:Key="InfoBrush" Color="#31708E" />
    <SolidColorBrush x:Key="InfoSoftBrush" Color="#E3EEF3" />

    <!-- ============================================================
         GHI DE THEME HANDYCONTROL: cac control cua HandyControl
         (DataGrid, ComboBox, DatePicker, Growl...) tu doi sang mau
         thuong hieu nho cac key duoi day (HC tra cuu bang DynamicResource).
         ============================================================ -->
    <SolidColorBrush x:Key="PrimaryBrush" Color="#34613C" />
    <SolidColorBrush x:Key="DarkPrimaryBrush" Color="#27492D" />
    <SolidColorBrush x:Key="LightPrimaryBrush" Color="#4E7D55" />
    <SolidColorBrush x:Key="TitleBrush" Color="#1D231D" />
    <SolidColorBrush x:Key="PrimaryTextBrush" Color="#1D231D" />
    <SolidColorBrush x:Key="SecondaryTextBrush" Color="#646B5E" />
    <SolidColorBrush x:Key="RegionBrush" Color="#FCFCFA" />
    <SolidColorBrush x:Key="SecondaryRegionBrush" Color="#F3F4F0" />

</ResourceDictionary>
