<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                    xmlns:enums="clr-namespace:BusinessObjects.Enums;assembly=BusinessObjects">

    <!-- Converter co san cua WPF: bool -> Visibility, dung cho IsLoading/IsEmpty... -->
    <BooleanToVisibilityConverter x:Key="BoolToVis" />

    <!-- HE BO GOC (quy uoc, xem docs/QUY_UOC_GIAO_DIEN.md):
         nut=pill(999) | o nhap=8 | card/dialog=12 | nav item=10 | badge=pill -->

    <!-- Bong khuech tan mem cho card/dialog - CAM bong den gat -->
    <DropShadowEffect x:Key="SoftShadow" BlurRadius="26" ShadowDepth="2" Direction="270"
                      Opacity="0.10" Color="#1D231D" />
    <DropShadowEffect x:Key="SoftShadowLarge" BlurRadius="40" ShadowDepth="4" Direction="270"
                      Opacity="0.14" Color="#1D231D" />

    <!-- ============================================================
         DESIGN TOKENS: CONTROL DUNG CHUNG.
         Cac control phuc tap (DataGrid, ComboBox, DatePicker, Growl...)
         da co HandyControl lo va tu an theo mau o Colors.xaml.
         File nay chi dinh nghia cac khoi nhan dien rieng cua app.
         ============================================================ -->

    <!-- Nut chinh: mau thuong hieu, bo tron kieu pill - dung cho hanh dong chinh cua man.
         Co phan hoi vat ly: nhan xuong scale 0.98 (haptic press) -->
    <Style x:Key="PrimaryButton" TargetType="Button">
        <Setter Property="Background" Value="{StaticResource BrandBrush}" />
        <Setter Property="Foreground" Value="White" />
        <Setter Property="FontWeight" Value="SemiBold" />
        <Setter Property="Padding" Value="18,10" />
        <Setter Property="Cursor" Value="Hand" />
        <Setter Property="RenderTransformOrigin" Value="0.5,0.5" />
        <Setter Property="RenderTransform">
            <Setter.Value>
                <ScaleTransform ScaleX="1" ScaleY="1" />
            </Setter.Value>
        </Setter>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="Button">
                    <Border x:Name="bd" Background="{TemplateBinding Background}"
                            CornerRadius="999" Padding="{TemplateBinding Padding}">
                        <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" />
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="bd" Property="Background" Value="{StaticResource BrandDarkBrush}" />
                        </Trigger>
                        <Trigger Property="IsEnabled" Value="False">
                            <Setter TargetName="bd" Property="Opacity" Value="0.5" />
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
        <Style.Triggers>
            <Trigger Property="IsPressed" Value="True">
                <Setter Property="RenderTransform">
                    <Setter.Value>
                        <ScaleTransform ScaleX="0.98" ScaleY="0.98" />
                    </Setter.Value>
                </Setter>
            </Trigger>
        </Style.Triggers>
    </Style>

    <!-- Nut phu: nen trong, vien mo - dung cho hanh dong thu cap -->
    <Style x:Key="GhostButton" TargetType="Button">
        <Setter Property="Background" Value="Transparent" />
        <Setter Property="Foreground" Value="{StaticResource InkBrush}" />
        <Setter Property="FontWeight" Value="SemiBold" />
        <Setter Property="Padding" Value="14,8" />
        <Setter Property="Cursor" Value="Hand" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="Button">
                    <Border x:Name="bd" Background="{TemplateBinding Background}"
                            CornerRadius="999" Padding="{TemplateBinding Padding}"
                            BorderBrush="{StaticResource LineBrush}" BorderThickness="1">
                        <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" />
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="bd" Property="Background" Value="{StaticResource SurfaceAltBrush}" />
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- O nhap chu: ap TOAN APP (style ngam) de moi module dong nhat,
         khong ai phai tu style TextBox nua.
         Validate: ViewModel ke thua ValidatableViewModelBase + AddError("TenProperty", "...")
         => o binding vao property do TU DONG vien do + tooltip loi (trigger Validation.HasError). -->
    <Style TargetType="TextBox">
        <Setter Property="Padding" Value="10,8" />
        <Setter Property="Background" Value="White" />
        <Setter Property="Foreground" Value="{StaticResource InkBrush}" />
        <Setter Property="BorderBrush" Value="{StaticResource LineBrush}" />
        <Setter Property="FontSize" Value="13" />
        <!-- Tat adorner do mac dinh cua WPF (ve de len ngoai khung) - da co vien do + tooltip -->
        <Setter Property="Validation.ErrorTemplate" Value="{x:Null}" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="TextBox">
                    <Border Background="{TemplateBinding Background}" CornerRadius="8"
                            BorderBrush="{TemplateBinding BorderBrush}" BorderThickness="1">
                        <ScrollViewer x:Name="PART_ContentHost" Margin="{TemplateBinding Padding}" />
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsKeyboardFocused" Value="True">
                            <Setter Property="BorderBrush" Value="{StaticResource BrandBrush}" />
                        </Trigger>
                        <!-- Dat SAU IsKeyboardFocused de loi thang mau focus khi ca hai cung xay ra -->
                        <Trigger Property="Validation.HasError" Value="True">
                            <Setter Property="BorderBrush" Value="{StaticResource DangerBrush}" />
                            <Setter Property="ToolTip"
                                    Value="{Binding RelativeSource={RelativeSource Self}, Path=(Validation.Errors)[0].ErrorContent}" />
                        </Trigger>
                        <Trigger Property="IsEnabled" Value="False">
                            <Setter Property="Opacity" Value="0.55" />
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>
    <!-- Alias giu tuong thich cho cho nao muon ghi ro rang -->
    <Style x:Key="InputBox" TargetType="TextBox" BasedOn="{StaticResource {x:Type TextBox}}" />

    <!-- O nhap mat khau: ap toan app, giong TextBox -->
    <Style TargetType="PasswordBox">
        <Setter Property="Padding" Value="10,8" />
        <Setter Property="Background" Value="White" />
        <Setter Property="Foreground" Value="{StaticResource InkBrush}" />
        <Setter Property="BorderBrush" Value="{StaticResource LineBrush}" />
        <Setter Property="FontSize" Value="13" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="PasswordBox">
                    <Border Background="{TemplateBinding Background}" CornerRadius="8"
                            BorderBrush="{TemplateBinding BorderBrush}" BorderThickness="1">
                        <ScrollViewer x:Name="PART_ContentHost" Margin="{TemplateBinding Padding}" />
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsKeyboardFocused" Value="True">
                            <Setter Property="BorderBrush" Value="{StaticResource BrandBrush}" />
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>
    <Style x:Key="InputPasswordBox" TargetType="PasswordBox" BasedOn="{StaticResource {x:Type PasswordBox}}" />

    <!-- Card: khoi noi dung bo goc, moi panel/section trong module boc bang cai nay.
         Muon co chieu sau (dialog, card noi) thi them Effect="{StaticResource SoftShadow}" -->
    <Style x:Key="Card" TargetType="Border">
        <Setter Property="Background" Value="{StaticResource CardBrush}" />
        <Setter Property="BorderBrush" Value="{StaticResource LineBrush}" />
        <Setter Property="BorderThickness" Value="1" />
        <Setter Property="CornerRadius" Value="12" />
        <Setter Property="Padding" Value="18" />
    </Style>

    <!-- Badge: pill nho hien trang thai (Dang o / Da dat / Trong / Qua han...).
         Dung: <Border Style="{StaticResource BadgeSuccess}"><TextBlock Text="Trong"/></Border> -->
    <Style x:Key="BadgeBase" TargetType="Border">
        <Setter Property="CornerRadius" Value="999" />
        <Setter Property="Padding" Value="10,3.5" />
        <Setter Property="HorizontalAlignment" Value="Left" />
        <Setter Property="TextElement.FontSize" Value="11.5" />
        <Setter Property="TextElement.FontWeight" Value="SemiBold" />
    </Style>
    <Style x:Key="BadgeSuccess" TargetType="Border" BasedOn="{StaticResource BadgeBase}">
        <Setter Property="Background" Value="{StaticResource SuccessSoftBrush}" />
        <Setter Property="TextElement.Foreground" Value="{StaticResource SuccessBrush}" />
    </Style>
    <Style x:Key="BadgeWarning" TargetType="Border" BasedOn="{StaticResource BadgeBase}">
        <Setter Property="Background" Value="{StaticResource WarningSoftBrush}" />
        <Setter Property="TextElement.Foreground" Value="{StaticResource WarningBrush}" />
    </Style>
    <Style x:Key="BadgeDanger" TargetType="Border" BasedOn="{StaticResource BadgeBase}">
        <Setter Property="Background" Value="{StaticResource DangerSoftBrush}" />
        <Setter Property="TextElement.Foreground" Value="{StaticResource DangerBrush}" />
    </Style>
    <Style x:Key="BadgeInfo" TargetType="Border" BasedOn="{StaticResource BadgeBase}">
        <Setter Property="Background" Value="{StaticResource InfoSoftBrush}" />
        <Setter Property="TextElement.Foreground" Value="{StaticResource InfoBrush}" />
    </Style>
    <Style x:Key="BadgeNeutral" TargetType="Border" BasedOn="{StaticResource BadgeBase}">
        <Setter Property="Background" Value="{StaticResource SurfaceAltBrush}" />
        <Setter Property="TextElement.Foreground" Value="{StaticResource InkSoftBrush}" />
    </Style>

    <!-- DataGrid: hang chon nen NHAT chu van den (khong duoc xanh dam nuot chu),
         cell can giua doc, bo vien focus mac dinh. Bang boc trong Card, header
         chu nho dam mo, hang ngan cach bang hairline -->
    <Style x:Key="AppColumnHeaderStyle" TargetType="DataGridColumnHeader">
        <Setter Property="Background" Value="Transparent" />
        <Setter Property="Foreground" Value="{StaticResource InkSoftBrush}" />
        <Setter Property="FontSize" Value="11" />
        <Setter Property="FontWeight" Value="Bold" />
        <Setter Property="Padding" Value="8,10" />
        <Setter Property="BorderBrush" Value="{StaticResource LineBrush}" />
        <Setter Property="BorderThickness" Value="0,0,0,1" />
    </Style>
    <Style x:Key="AppRowStyle" TargetType="DataGridRow">
        <Setter Property="Background" Value="Transparent" />
        <Setter Property="BorderBrush" Value="{StaticResource LineBrush}" />
        <Setter Property="BorderThickness" Value="0,0,0,1" />
        <Setter Property="SnapsToDevicePixels" Value="True" />
        <!-- Template tu ve: template hang cua HandyControl to mau chon bang PrimaryBrush
             (xanh dam nuot chu) - thay bang template don gian de Background/trigger cua ta co tac dung -->
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="DataGridRow">
                    <Border Background="{TemplateBinding Background}"
                            BorderBrush="{TemplateBinding BorderBrush}"
                            BorderThickness="{TemplateBinding BorderThickness}">
                        <DataGridCellsPresenter ItemsPanel="{TemplateBinding ItemsPanel}"
                                                SnapsToDevicePixels="{TemplateBinding SnapsToDevicePixels}" />
                    </Border>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
        <Style.Triggers>
            <Trigger Property="IsMouseOver" Value="True">
                <Setter Property="Background" Value="#0A000000" />
            </Trigger>
            <Trigger Property="IsSelected" Value="True">
                <Setter Property="Background" Value="{StaticResource BrandSoftBrush}" />
                <Setter Property="Foreground" Value="{StaticResource InkBrush}" />
            </Trigger>
        </Style.Triggers>
    </Style>
    <Style x:Key="AppCellStyle" TargetType="DataGridCell">
        <Setter Property="Background" Value="Transparent" />
        <Setter Property="BorderThickness" Value="0" />
        <Setter Property="Padding" Value="8,0" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="DataGridCell">
                    <Border Background="{TemplateBinding Background}"
                            Padding="{TemplateBinding Padding}">
                        <ContentPresenter VerticalAlignment="Center" />
                    </Border>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
        <Style.Triggers>
            <Trigger Property="IsSelected" Value="True">
                <Setter Property="Background" Value="Transparent" />
                <Setter Property="Foreground" Value="{StaticResource InkBrush}" />
            </Trigger>
        </Style.Triggers>
    </Style>

    <!-- Style ngam DataGrid CUA TA thay the han style cua HandyControl:
         HC gan RowStyle tuong minh trong style DataGrid cua no nen moi style ngam
         DataGridRow deu bi bo qua -> phai chiem quyen o cap DataGrid va tu gan
         Row/Cell/Header style cua minh. Module chi can dat <DataGrid> la dep san. -->
    <Style TargetType="DataGrid">
        <Setter Property="ColumnHeaderStyle" Value="{StaticResource AppColumnHeaderStyle}" />
        <Setter Property="RowStyle" Value="{StaticResource AppRowStyle}" />
        <Setter Property="CellStyle" Value="{StaticResource AppCellStyle}" />
        <Setter Property="Background" Value="Transparent" />
        <Setter Property="BorderThickness" Value="0" />
        <Setter Property="RowHeight" Value="46" />
        <Setter Property="GridLinesVisibility" Value="None" />
        <Setter Property="RowHeaderWidth" Value="0" />
        <Setter Property="RowBackground" Value="Transparent" />
        <Setter Property="AlternatingRowBackground" Value="Transparent" />
        <Setter Property="AutoGenerateColumns" Value="False" />
        <Setter Property="CanUserAddRows" Value="False" />
        <Setter Property="HeadersVisibility" Value="Column" />
        <Setter Property="SelectionMode" Value="Single" />
        <Setter Property="SelectionUnit" Value="FullRow" />
    </Style>

    <!-- Badge trang thai PHONG: dung cho row co property Room (RoomRow).
         Mau theo nghiep vu: Trong=xanh, Da dat=info, Dang o=am, Dang don=trung tinh, Bao tri=do -->
    <Style x:Key="RoomStatusBadge" TargetType="Border" BasedOn="{StaticResource BadgeBase}">
        <Style.Triggers>
            <DataTrigger Binding="{Binding Room.Status}" Value="{x:Static enums:RoomStatus.Available}">
                <Setter Property="Background" Value="{StaticResource SuccessSoftBrush}" />
                <Setter Property="TextElement.Foreground" Value="{StaticResource SuccessBrush}" />
            </DataTrigger>
            <DataTrigger Binding="{Binding Room.Status}" Value="{x:Static enums:RoomStatus.Reserved}">
                <Setter Property="Background" Value="{StaticResource InfoSoftBrush}" />
                <Setter Property="TextElement.Foreground" Value="{StaticResource InfoBrush}" />
            </DataTrigger>
            <DataTrigger Binding="{Binding Room.Status}" Value="{x:Static enums:RoomStatus.Occupied}">
                <Setter Property="Background" Value="{StaticResource WarningSoftBrush}" />
                <Setter Property="TextElement.Foreground" Value="{StaticResource WarningBrush}" />
            </DataTrigger>
            <DataTrigger Binding="{Binding Room.Status}" Value="{x:Static enums:RoomStatus.Cleaning}">
                <Setter Property="Background" Value="{StaticResource SurfaceAltBrush}" />
                <Setter Property="TextElement.Foreground" Value="{StaticResource InkSoftBrush}" />
            </DataTrigger>
            <DataTrigger Binding="{Binding Room.Status}" Value="{x:Static enums:RoomStatus.Maintenance}">
                <Setter Property="Background" Value="{StaticResource DangerSoftBrush}" />
                <Setter Property="TextElement.Foreground" Value="{StaticResource DangerBrush}" />
            </DataTrigger>
        </Style.Triggers>
    </Style>

    <!-- Muc dieu huong sidebar: item chon co thanh nhan thuong hieu ben trai + nen nhat -->
    <Style x:Key="NavItem" TargetType="ListBoxItem">
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="ListBoxItem">
                    <Grid Margin="0,2">
                        <Border x:Name="bd" CornerRadius="10" Padding="14,10" Background="Transparent" />
                        <Rectangle x:Name="accent" Width="3.5" RadiusX="2" RadiusY="2"
                                   Fill="{StaticResource BrandBrush}" HorizontalAlignment="Left"
                                   Margin="2,8" Visibility="Collapsed" />
                        <ContentPresenter x:Name="cp" Margin="16,10,14,10" VerticalAlignment="Center" />
                    </Grid>
                    <ControlTemplate.Triggers>
                        <!-- Hover phai NHAT han selected de khong bi 2 item sang gan bang nhau -->
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="bd" Property="Background" Value="#0E000000" />
                        </Trigger>
                        <Trigger Property="IsSelected" Value="True">
                            <Setter TargetName="bd" Property="Background" Value="{StaticResource BrandSoftBrush}" />
                            <Setter TargetName="accent" Property="Visibility" Value="Visible" />
                            <Setter TargetName="cp" Property="TextElement.FontWeight" Value="SemiBold" />
                            <Setter TargetName="cp" Property="TextElement.Foreground" Value="{StaticResource BrandDarkBrush}" />
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

</ResourceDictionary>
